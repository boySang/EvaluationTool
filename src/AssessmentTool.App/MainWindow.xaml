<Window x:Class="AssessmentTool.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:automation="clr-namespace:System.Windows.Automation;assembly=PresentationCore"
        xmlns:core="clr-namespace:AssessmentTool.Core.Domain;assembly=AssessmentTool.Core"
        xmlns:storage="clr-namespace:AssessmentTool.Windows.Storage;assembly=AssessmentTool.Windows"
        xmlns:viewModels="clr-namespace:AssessmentTool.App.ViewModels"
        Title="等级保护测评辅助工具"
        Width="1440"
        Height="900"
        MinWidth="1100"
        MinHeight="720"
        WindowStartupLocation="CenterScreen"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
  <Grid Background="{DynamicResource Brush.Window}">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="216" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>

    <Border Grid.Column="0"
            Background="{DynamicResource Brush.Navigation}"
            BorderBrush="{DynamicResource Brush.Border}"
            BorderThickness="0,0,1,0">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="72" />
          <RowDefinition Height="*" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="16,16,10,12" VerticalAlignment="Center">
          <Border Width="38" Height="38" CornerRadius="8" Background="{DynamicResource Brush.Accent}" Margin="0,0,10,0">
            <TextBlock Text="&#xEA18;" Style="{StaticResource FluentSymbolStyle}" Foreground="White" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Border>
          <StackPanel VerticalAlignment="Center">
            <TextBlock Text="EvaluationTool" FontWeight="SemiBold" FontSize="15" />
            <TextBlock Text="等级保护测评辅助工具" Foreground="{DynamicResource Brush.TextSecondary}" FontSize="10.5" />
          </StackPanel>
        </StackPanel>

        <ListBox x:Name="ShellNavigation"
                 Grid.Row="1"
                 SelectedIndex="0"
                 Style="{StaticResource ShellNavigationStyle}"
                 ItemContainerStyle="{StaticResource ShellNavigationItemStyle}"
                 automation:AutomationProperties.Name="主导航">
          <ListBoxItem automation:AutomationProperties.Name="导航：首页">
            <StackPanel Orientation="Horizontal"><TextBlock Text="&#xE80F;" Style="{StaticResource NavigationIconStyle}" /><TextBlock Text="首页" VerticalAlignment="Center" /></StackPanel>
          </ListBoxItem>
          <ListBoxItem automation:AutomationProperties.Name="导航：项目">
            <StackPanel Orientation="Horizontal"><TextBlock Text="&#xE8B7;" Style="{StaticResource NavigationIconStyle}" /><TextBlock Text="项目" VerticalAlignment="Center" /></StackPanel>
          </ListBoxItem>
          <ListBoxItem automation:AutomationProperties.Name="导航：设备">
            <StackPanel Orientation="Horizontal"><TextBlock Text="&#xE770;" Style="{StaticResource NavigationIconStyle}" /><TextBlock Text="设备" VerticalAlignment="Center" /></StackPanel>
          </ListBoxItem>
          <ListBoxItem automation:AutomationProperties.Name="导航：采集任务">
            <StackPanel Orientation="Horizontal"><TextBlock Text="&#xE9D5;" Style="{StaticResource NavigationIconStyle}" /><TextBlock Text="采集任务" VerticalAlignment="Center" /></StackPanel>
          </ListBoxItem>
          <ListBoxItem automation:AutomationProperties.Name="导航：证据中心">
            <StackPanel Orientation="Horizontal"><TextBlock Text="&#xE8A5;" Style="{StaticResource NavigationIconStyle}" /><TextBlock Text="证据中心" VerticalAlignment="Center" /></StackPanel>
          </ListBoxItem>
          <ListBoxItem automation:AutomationProperties.Name="导航：命令库">
            <StackPanel Orientation="Horizontal"><TextBlock Text="&#xE756;" Style="{StaticResource NavigationIconStyle}" /><TextBlock Text="命令库" VerticalAlignment="Center" /></StackPanel>
          </ListBoxItem>
          <ListBoxItem automation:AutomationProperties.Name="导航：组件中心">
            <StackPanel Orientation="Horizontal"><TextBlock Text="&#xE71D;" Style="{StaticResource NavigationIconStyle}" /><TextBlock Text="组件中心" VerticalAlignment="Center" /></StackPanel>
          </ListBoxItem>
          <ListBoxItem IsEnabled="False" automation:AutomationProperties.Name="导航：设置">
            <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="39" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><TextBlock Text="&#xE713;" Style="{StaticResource NavigationIconStyle}" /><TextBlock Grid.Column="1" Text="设置" /><TextBlock Grid.Column="2" Text="后续" FontSize="10" Foreground="{DynamicResource Brush.DisabledText}" /></Grid>
          </ListBoxItem>
        </ListBox>

        <StackPanel Grid.Row="2" Margin="16,10,16,18">
          <Border Style="{StaticResource ReadOnlyPillStyle}" HorizontalAlignment="Left">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="●" Foreground="{DynamicResource Brush.Success}" FontSize="10" Margin="0,0,7,0" VerticalAlignment="Center" />
              <TextBlock Text="只读保护已开启" FontSize="12" Foreground="{DynamicResource Brush.Success}" />
            </StackPanel>
          </Border>
          <TextBlock Text="本地离线运行 · 不自动上传" Style="{StaticResource SecondaryTextStyle}" FontSize="11" Margin="0,8,0,0" />
        </StackPanel>
      </Grid>
    </Border>

    <Grid Grid.Column="1">
      <Grid.RowDefinitions>
        <RowDefinition Height="58" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>

      <Border Grid.Row="0" Background="{DynamicResource Brush.Surface}" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="0,0,0,1" Padding="22,0">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>
          <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <TextBlock Text="&#xE8B7;" Style="{StaticResource FluentSymbolStyle}" Foreground="{DynamicResource Brush.TextSecondary}" Margin="0,0,8,0" />
            <TextBlock Text="项目：" Foreground="{DynamicResource Brush.TextSecondary}" />
            <TextBlock Text="{Binding CurrentProjectName}" FontWeight="SemiBold" MaxWidth="360" TextTrimming="CharacterEllipsis" ToolTip="{Binding CurrentProjectName}" />
            <Border Width="1" Height="18" Background="{DynamicResource Brush.Border}" Margin="16,0" />
            <TextBlock Text="&#xE770;" Style="{StaticResource FluentSymbolStyle}" Foreground="{DynamicResource Brush.TextSecondary}" Margin="0,0,8,0" />
            <TextBlock Text="设备：" Foreground="{DynamicResource Brush.TextSecondary}" />
            <TextBlock Text="{Binding CurrentDeviceName}" FontWeight="SemiBold" MaxWidth="260" TextTrimming="CharacterEllipsis" ToolTip="{Binding CurrentDeviceName}" />
          </StackPanel>
          <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
            <Border x:Name="ReadOnlyStatusBadge" Style="{StaticResource ReadOnlyPillStyle}" Margin="0,0,12,0">
              <StackPanel Orientation="Horizontal">
                <TextBlock Text="✓" Foreground="{DynamicResource Brush.Success}" Margin="0,0,6,0" />
                <TextBlock Text="{Binding ReadOnlyProtectionStatus}" Foreground="{DynamicResource Brush.Success}" FontSize="12" />
              </StackPanel>
            </Border>
            <Button Content="&#xE708;"
                    FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                    Style="{StaticResource FluentIconButtonStyle}"
                    Command="{Binding ToggleThemeCommand}"
                    automation:AutomationProperties.Name="切换浅色或深色主题" />
          </StackPanel>
        </Grid>
      </Border>

      <TabControl Grid.Row="1"
                  Style="{StaticResource ContentOnlyTabControlStyle}"
                  SelectedIndex="{Binding SelectedIndex, ElementName=ShellNavigation, Mode=OneWay}"
                  automation:AutomationProperties.Name="页面内容">
      <TabItem Header="首页">
        <Grid x:Name="HomeDashboardPanel" Margin="24">
          <Grid.RowDefinitions>
            <RowDefinition Height="146" />
            <RowDefinition Height="16" />
            <RowDefinition Height="104" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>

          <Border Grid.Row="0" Style="{StaticResource FluentCardStyle}" Background="{DynamicResource Brush.SurfaceSubtle}">
            <Grid>
              <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="330" /></Grid.ColumnDefinitions>
              <StackPanel VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal">
                  <TextBlock Text="项目测评工作台" Style="{StaticResource PageTitleStyle}" Margin="0,0,12,6" />
                  <Border Style="{StaticResource ReadOnlyPillStyle}" VerticalAlignment="Top">
                    <TextBlock Text="只读模式" Foreground="{DynamicResource Brush.Success}" FontSize="11" />
                  </Border>
                </StackPanel>
                <TextBlock Text="管理当前项目设备、只读采集任务和测评证据。所有自动命令在执行前都要通过安全策略校验。" Style="{StaticResource SecondaryTextStyle}" />
                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                  <Button Content="＋  新建项目" Click="NavigateToProjects_Click" automation:AutomationProperties.Name="转到项目页面新建项目" />
                  <Button Content="添加设备" Style="{StaticResource FluentSecondaryButtonStyle}" Click="NavigateToDevices_Click" automation:AutomationProperties.Name="转到设备页面添加设备" />
                </StackPanel>
              </StackPanel>
              <Border Grid.Column="1" Background="{DynamicResource Brush.SurfaceMuted}" CornerRadius="0,10,10,0" Margin="18,-18,-18,-18" ClipToBounds="True">
                <Image Source="/AssessmentTool.App;component/Assets/network-security-hero.png"
                       Stretch="UniformToFill"
                       automation:AutomationProperties.Name="只读网络测评安全示意图" />
              </Border>
            </Grid>
          </Border>

          <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" /><ColumnDefinition Width="12" />
              <ColumnDefinition Width="*" /><ColumnDefinition Width="12" />
              <ColumnDefinition Width="*" /><ColumnDefinition Width="12" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Style="{StaticResource DashboardStatCardStyle}">
              <StackPanel><TextBlock Text="项目设备" Style="{StaticResource SecondaryTextStyle}" /><TextBlock x:Name="DashboardDeviceCount" Text="{Binding ProjectDeviceCount, Mode=OneWay}" Style="{StaticResource DashboardMetricStyle}" /><TextBlock Text="当前项目已保存的设备" Style="{StaticResource SecondaryTextStyle}" FontSize="11" /></StackPanel>
            </Border>
            <Border Grid.Column="2" Style="{StaticResource DashboardStatCardStyle}">
              <StackPanel><TextBlock Text="连接测试通过" Style="{StaticResource SecondaryTextStyle}" /><TextBlock Text="{Binding SuccessfulConnectionTestCount, Mode=OneWay}" Style="{StaticResource DashboardMetricStyle}" /><TextBlock Text="完成指纹确认和登录测试" Style="{StaticResource SecondaryTextStyle}" FontSize="11" /></StackPanel>
            </Border>
            <Border Grid.Column="4" Style="{StaticResource DashboardStatCardStyle}">
              <StackPanel><TextBlock Text="待连接测试" Style="{StaticResource SecondaryTextStyle}" /><TextBlock Text="{Binding PendingConnectionTestCount, Mode=OneWay}" Style="{StaticResource DashboardMetricStyle}" /><TextBlock Text="尚未完成安全连接闭环" Style="{StaticResource SecondaryTextStyle}" FontSize="11" /></StackPanel>
            </Border>
            <Border Grid.Column="6" Style="{StaticResource DashboardStatCardStyle}">
              <StackPanel><TextBlock Text="采集失败" Style="{StaticResource SecondaryTextStyle}" /><TextBlock Text="{Binding CollectionFailureCount, Mode=OneWay}" Style="{StaticResource DashboardMetricStyle}" Foreground="{DynamicResource Brush.Error}" /><TextBlock Text="当前会话需要处理的失败" Style="{StaticResource SecondaryTextStyle}" FontSize="11" /></StackPanel>
            </Border>
          </Grid>

          <Grid Grid.Row="4">
            <Grid.ColumnDefinitions><ColumnDefinition Width="2*" /><ColumnDefinition Width="16" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
            <Border Grid.Column="0" Style="{StaticResource FluentCardStyle}" Padding="0">
              <Grid>
                <Grid.RowDefinitions><RowDefinition Height="54" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                <Grid Grid.Row="0" Margin="16,0">
                  <TextBlock Text="最近设备" Style="{StaticResource SectionTitleStyle}" Margin="0" VerticalAlignment="Center" />
                  <Button Content="进入设备列表" Style="{StaticResource FluentSecondaryButtonStyle}" HorizontalAlignment="Right" VerticalAlignment="Center" Click="NavigateToDevices_Click" />
                </Grid>
                <ListBox Grid.Row="1" ItemsSource="{Binding Workspace.Devices}" IsHitTestVisible="False" Focusable="False" BorderThickness="0" ItemContainerStyle="{StaticResource DashboardListItemStyle}" automation:AutomationProperties.Name="最近设备只读列表">
                  <ListBox.ItemTemplate>
                    <DataTemplate>
                      <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="2*" /><ColumnDefinition Width="1.5*" /><ColumnDefinition Width="100" /></Grid.ColumnDefinitions>
                        <StackPanel><TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" /><TextBlock Text="SSH 设备" Style="{StaticResource SecondaryTextStyle}" FontSize="11" /></StackPanel>
                        <TextBlock Grid.Column="1" Text="{Binding Host}" VerticalAlignment="Center" FontFamily="Consolas" />
                        <Border Grid.Column="2" Background="{DynamicResource Brush.WarningBackground}" CornerRadius="10" Padding="8,3" HorizontalAlignment="Left" VerticalAlignment="Center"><TextBlock Text="待连接测试" Foreground="{DynamicResource Brush.WarningText}" FontSize="11" /></Border>
                      </Grid>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
                <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                  <StackPanel.Style>
                    <Style TargetType="StackPanel">
                      <Setter Property="Visibility" Value="Collapsed" />
                      <Style.Triggers><DataTrigger Binding="{Binding ProjectDeviceCount}" Value="0"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers>
                    </Style>
                  </StackPanel.Style>
                  <TextBlock Text="尚未添加设备" FontWeight="SemiBold" HorizontalAlignment="Center" />
                  <TextBlock Text="先选择项目，再添加需要测评的设备。" Style="{StaticResource SecondaryTextStyle}" Margin="0,6,0,8" />
                  <Button Content="添加第一台设备" Click="NavigateToDevices_Click" />
                </StackPanel>
              </Grid>
            </Border>

            <StackPanel Grid.Column="2">
              <Border Style="{StaticResource FluentCardStyle}" Margin="0,0,0,12">
                <StackPanel>
                  <TextBlock Text="待处理事项" Style="{StaticResource SectionTitleStyle}" />
                  <Grid Margin="0,4"><TextBlock Text="设备待连接测试" /><Border Background="{DynamicResource Brush.WarningBackground}" CornerRadius="10" Padding="8,2" HorizontalAlignment="Right"><TextBlock Text="{Binding PendingConnectionTestCount, Mode=OneWay}" Foreground="{DynamicResource Brush.WarningText}" /></Border></Grid>
                  <Grid Margin="0,8,0,4"><TextBlock Text="采集失败" /><Border Background="{DynamicResource Brush.ErrorBackground}" CornerRadius="10" Padding="8,2" HorizontalAlignment="Right"><TextBlock Text="{Binding CollectionFailureCount, Mode=OneWay}" Foreground="{DynamicResource Brush.Error}" /></Border></Grid>
                </StackPanel>
              </Border>
              <Border Style="{StaticResource FluentCardStyle}">
                <StackPanel>
                  <TextBlock Text="运行环境" Style="{StaticResource SectionTitleStyle}" />
                  <TextBlock Text="SSH 连接组件" FontWeight="SemiBold" />
                  <TextBlock Text="{Binding ComponentCenter.StatusText, Mode=OneWay}" Style="{StaticResource SecondaryTextStyle}" Margin="0,5,0,10" />
                  <Button Content="查看组件中心" Style="{StaticResource FluentSecondaryButtonStyle}" Click="NavigateToComponents_Click" HorizontalAlignment="Left" />
                </StackPanel>
              </Border>
            </StackPanel>
          </Grid>
        </Grid>
      </TabItem>

      <TabItem Header="项目">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
          <StackPanel Margin="28" MaxWidth="760" HorizontalAlignment="Left">
            <TextBlock Text="客户与项目" Style="{StaticResource PageTitleStyle}" />
            <TextBlock Text="项目资料将用于证据目录和执行记录。不会自动上传客户数据。" Style="{StaticResource SecondaryTextStyle}" Margin="0,0,0,20" />
            <Border Style="{StaticResource CardStyle}">
              <StackPanel>
                <TextBlock Text="新建项目" Style="{StaticResource SectionTitleStyle}" />
                <TextBlock Text="客户名称" />
                <TextBox Text="{Binding Workspace.CustomerName, UpdateSourceTrigger=PropertyChanged}" automation:AutomationProperties.Name="客户名称" />
                <TextBlock Text="项目名称" />
                <TextBox Text="{Binding Workspace.ProjectName, UpdateSourceTrigger=PropertyChanged}" automation:AutomationProperties.Name="项目名称" />
                <TextBlock Text="证据保存目录" />
                <TextBox Text="{Binding Workspace.EvidenceRoot, UpdateSourceTrigger=PropertyChanged}" automation:AutomationProperties.Name="证据保存目录" />
                <Button Content="创建并保存项目" Click="CreateProject_Click" automation:AutomationProperties.Name="创建并保存项目" />
                <TextBlock Text="项目资料保存在当前 Windows 用户的本地 SQLite 数据库中，不会自动上传。" Style="{StaticResource SecondaryTextStyle}" />
              </StackPanel>
            </Border>
            <Border Style="{StaticResource CardStyle}">
              <StackPanel>
                <TextBlock Text="已保存项目" Style="{StaticResource SectionTitleStyle}" />
                <ListBox ItemsSource="{Binding Workspace.Projects}"
                         IsEnabled="{Binding IsWorkspaceSelectionEnabled}"
                         SelectedItem="{Binding Workspace.SelectedProject, Mode=OneWay}"
                         SelectionChanged="ProjectSelection_Changed"
                         MinHeight="120"
                         automation:AutomationProperties.Name="已保存项目列表">
                  <ListBox.ItemTemplate>
                    <DataTemplate>
                      <StackPanel Margin="4">
                        <TextBlock Text="{Binding ProjectName}" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding CustomerName}" Style="{StaticResource SecondaryTextStyle}" />
                      </StackPanel>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
              </StackPanel>
            </Border>
            <Border BorderBrush="{DynamicResource Brush.Error}" BorderThickness="1" Background="{DynamicResource Brush.ErrorBackground}" CornerRadius="10" Padding="20">
              <Border.Style>
                <Style TargetType="Border">
                  <Setter Property="Visibility" Value="Collapsed" />
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding Workspace.State}" Value="Failed"><Setter Property="Visibility" Value="Visible" /></DataTrigger>
                  </Style.Triggers>
                </Style>
              </Border.Style>
              <StackPanel automation:AutomationProperties.LiveSetting="Assertive">
                <TextBlock Text="{Binding Workspace.WhatHappened}" Foreground="{DynamicResource Brush.Error}" FontWeight="SemiBold" />
                <TextBlock Text="{Binding Workspace.PossibleCause}" TextWrapping="Wrap" Margin="0,8,0,0" />
                <TextBlock Text="{Binding Workspace.HowToFix}" TextWrapping="Wrap" Margin="0,8,0,0" />
                <Expander Header="技术详情" Margin="0,8,0,0">
                  <TextBox Text="{Binding Workspace.TechnicalDetails, Mode=OneWay}" IsReadOnly="True" />
                </Expander>
              </StackPanel>
            </Border>
          </StackPanel>
        </ScrollViewer>
      </TabItem>

      <TabItem Header="设备">
        <Grid>
        <Grid x:Name="DeviceListPanel" Margin="24">
          <Grid.Style>
            <Style TargetType="Grid">
              <Setter Property="Visibility" Value="Visible" />
              <Style.Triggers><DataTrigger Binding="{Binding DeviceEditor.IsOpen}" Value="True"><Setter Property="Visibility" Value="Collapsed" /></DataTrigger></Style.Triggers>
            </Style>
          </Grid.Style>
          <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="16" /><RowDefinition Height="*" /><RowDefinition Height="16" /><RowDefinition Height="Auto" /><RowDefinition Height="16" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
          <Grid Grid.Row="0">
            <StackPanel>
              <TextBlock Text="设备管理" Style="{StaticResource PageTitleStyle}" />
              <TextBlock Text="管理当前项目中的授权设备和安全连接资料。" Style="{StaticResource SecondaryTextStyle}" />
            </StackPanel>
            <Button Content="＋  添加设备" HorizontalAlignment="Right" VerticalAlignment="Center" IsEnabled="{Binding HasSelectedProject}" Click="OpenDeviceWizard_Click" automation:AutomationProperties.Name="打开添加设备向导" />
          </Grid>
          <Border Grid.Row="2" Style="{StaticResource FluentCardStyle}" Padding="0">
            <Grid>
              <Grid.RowDefinitions><RowDefinition Height="52" /><RowDefinition Height="42" /><RowDefinition Height="*" /></Grid.RowDefinitions>
              <Grid Grid.Row="0" Margin="16,7">
                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                <Grid>
                  <TextBlock Text="&#xE721;" Style="{StaticResource FluentSymbolStyle}" Foreground="{DynamicResource Brush.TextSecondary}" Margin="11,0,0,0" HorizontalAlignment="Left" Panel.ZIndex="1" />
                  <TextBlock Text="搜索设备名称、主机地址或账户…"
                             Foreground="{DynamicResource Brush.TextSecondary}"
                             Margin="36,0,10,0"
                             VerticalAlignment="Center"
                             IsHitTestVisible="False"
                             Panel.ZIndex="1">
                    <TextBlock.Style>
                      <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                          <DataTrigger Binding="{Binding DeviceSearchText}" Value="">
                            <Setter Property="Visibility" Value="Visible" />
                          </DataTrigger>
                        </Style.Triggers>
                      </Style>
                    </TextBlock.Style>
                  </TextBlock>
                  <TextBox Text="{Binding DeviceSearchText, UpdateSourceTrigger=PropertyChanged}"
                           Padding="36,7,10,7"
                           Margin="0"
                           MaxWidth="520"
                           HorizontalAlignment="Stretch"
                           automation:AutomationProperties.Name="按设备名称、主机地址或账户搜索" />
                </Grid>
                <TextBlock Grid.Column="1"
                           Text="{Binding FilteredDeviceCount, StringFormat=显示 {0} 台设备}"
                           Style="{StaticResource SecondaryTextStyle}"
                           Margin="18,0,0,0"
                           VerticalAlignment="Center" />
              </Grid>
              <Grid Grid.Row="1" Background="{DynamicResource Brush.SurfaceSubtle}" Margin="1,0">
                <Grid.ColumnDefinitions><ColumnDefinition Width="2*" /><ColumnDefinition Width="1.5*" /><ColumnDefinition Width="1.1*" /><ColumnDefinition Width="0.8*" /><ColumnDefinition Width="1.1*" /></Grid.ColumnDefinitions>
                <TextBlock Text="设备名称" FontWeight="SemiBold" Margin="14,0" VerticalAlignment="Center" />
                <TextBlock Grid.Column="1" Text="主机地址" FontWeight="SemiBold" VerticalAlignment="Center" />
                <TextBlock Grid.Column="2" Text="设备类别" FontWeight="SemiBold" VerticalAlignment="Center" />
                <TextBlock Grid.Column="3" Text="连接方式" FontWeight="SemiBold" VerticalAlignment="Center" />
                <TextBlock Grid.Column="4" Text="安全连接状态" FontWeight="SemiBold" VerticalAlignment="Center" />
              </Grid>
              <ListBox Grid.Row="2" ItemsSource="{Binding FilteredDevices, Mode=OneWay}" SelectedItem="{Binding Workspace.SelectedDevice, Mode=TwoWay}" IsEnabled="{Binding IsWorkspaceSelectionEnabled}" BorderThickness="0" ItemContainerStyle="{StaticResource DashboardListItemStyle}" automation:AutomationProperties.Name="当前项目设备列表">
                <ListBox.ItemTemplate>
                  <DataTemplate>
                    <Grid>
                      <Grid.ColumnDefinitions><ColumnDefinition Width="2*" /><ColumnDefinition Width="1.5*" /><ColumnDefinition Width="1.1*" /><ColumnDefinition Width="0.8*" /><ColumnDefinition Width="1.1*" /></Grid.ColumnDefinitions>
                      <StackPanel><TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" /><TextBlock Text="{Binding UserName, StringFormat=账户：{0}}" Style="{StaticResource SecondaryTextStyle}" FontSize="11" /></StackPanel>
                      <StackPanel Grid.Column="1" VerticalAlignment="Center"><TextBlock Text="{Binding Host}" FontFamily="Consolas" /><TextBlock Text="{Binding Port, StringFormat=端口 {0}}" Style="{StaticResource SecondaryTextStyle}" FontSize="11" /></StackPanel>
                      <TextBlock Grid.Column="2" Text="{Binding Category, Converter={StaticResource DeviceMetadataConverter}}" VerticalAlignment="Center" />
                      <TextBlock Grid.Column="3" Text="{Binding Protocol, Converter={StaticResource DeviceMetadataConverter}}" VerticalAlignment="Center" />
                      <Border Grid.Column="4" Background="{DynamicResource Brush.WarningBackground}" CornerRadius="10" Padding="8,3" HorizontalAlignment="Left" VerticalAlignment="Center"><TextBlock Text="待连接测试" Foreground="{DynamicResource Brush.WarningText}" FontSize="11" /></Border>
                    </Grid>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>
              <StackPanel Grid.Row="2" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel.Style><Style TargetType="StackPanel"><Setter Property="Visibility" Value="Collapsed" /><Style.Triggers><DataTrigger Binding="{Binding ProjectDeviceCount}" Value="0"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers></Style></StackPanel.Style>
                <TextBlock Text="当前项目还没有设备" FontWeight="SemiBold" HorizontalAlignment="Center" />
                <TextBlock Text="添加设备后，软件才会在授权范围内进行安全连接测试。" Style="{StaticResource SecondaryTextStyle}" Margin="0,6,0,10" />
                <Button Content="添加第一台设备" IsEnabled="{Binding HasSelectedProject}" Click="OpenDeviceWizard_Click" />
              </StackPanel>
            </Grid>
          </Border>
          <Border Grid.Row="4" Style="{StaticResource FluentCardStyle}" Padding="18" automation:AutomationProperties.Name="SSH 安全连接测试">
            <Grid>
              <Grid.ColumnDefinitions><ColumnDefinition Width="1.1*" /><ColumnDefinition Width="18" /><ColumnDefinition Width="2.1*" /><ColumnDefinition Width="18" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
              <StackPanel>
                <TextBlock Text="SSH 安全连接" Style="{StaticResource SectionTitleStyle}" />
                <TextBlock Text="自动探测指纹 → 人工确认 → 无命令测试登录" Style="{StaticResource SecondaryTextStyle}" FontSize="12" />
              </StackPanel>
              <StackPanel Grid.Column="2">
                <TextBlock Text="{Binding DeviceConnection.StatusMessage}" TextWrapping="Wrap" />
                <TextBlock Text="{Binding DeviceConnection.Algorithm, StringFormat=算法：{0}}" Style="{StaticResource SecondaryTextStyle}" FontSize="11" Margin="0,6,0,0" />
                <TextBlock Text="{Binding DeviceConnection.Fingerprint, StringFormat=指纹：{0}}" FontFamily="Consolas" FontSize="11" TextWrapping="Wrap" />
                <TextBlock Text="{Binding DeviceConnection.TechnicalDetails, StringFormat=技术信息：{0}}" Style="{StaticResource SecondaryTextStyle}" FontSize="11" />
              </StackPanel>
              <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Content="探测主机指纹" Style="{StaticResource FluentSecondaryButtonStyle}" IsEnabled="{Binding DeviceConnection.CanProbe}" Click="ProbeHostKey_Click" />
                <Button Content="确认并测试登录" IsEnabled="{Binding DeviceConnection.CanConfirm}" Click="ConfirmHostKeyAndTest_Click" />
              </StackPanel>
            </Grid>
          </Border>
          <Border Grid.Row="6" Style="{StaticResource FluentCardStyle}" Padding="18" automation:AutomationProperties.Name="最近设备识别结果">
            <Grid>
              <Grid.ColumnDefinitions><ColumnDefinition Width="1.1*" /><ColumnDefinition Width="18" /><ColumnDefinition Width="2.1*" /></Grid.ColumnDefinitions>
              <StackPanel>
                <TextBlock Text="设备身份" Style="{StaticResource SectionTitleStyle}" />
                <TextBlock Text="保留识别依据、可信度和人工确认来源" Style="{StaticResource SecondaryTextStyle}" FontSize="12" />
              </StackPanel>
              <StackPanel Grid.Column="2">
                <TextBlock Text="{Binding Workspace.IdentificationStatusMessage}" TextWrapping="Wrap" />
                <Grid Margin="0,10,0,0">
                  <Grid.Style>
                    <Style TargetType="Grid">
                      <Setter Property="Visibility" Value="Collapsed" />
                      <Style.Triggers><DataTrigger Binding="{Binding Workspace.HasSelectedIdentification}" Value="True"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers>
                    </Style>
                  </Grid.Style>
                  <Grid.ColumnDefinitions><ColumnDefinition Width="120" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                  <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                  <TextBlock Text="类别" Style="{StaticResource SecondaryTextStyle}" />
                  <TextBlock Grid.Column="1" Text="{Binding Workspace.SelectedIdentification.Category, Converter={StaticResource DeviceMetadataConverter}}" />
                  <TextBlock Grid.Row="1" Text="厂商 / 型号" Style="{StaticResource SecondaryTextStyle}" Margin="0,6,0,0" />
                  <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,6,0,0"><Run Text="{Binding Workspace.SelectedIdentification.Vendor, Mode=OneWay, TargetNullValue=未知厂商}" /><Run Text="  " /><Run Text="{Binding Workspace.SelectedIdentification.Model, Mode=OneWay, TargetNullValue=未知型号}" /></TextBlock>
                  <TextBlock Grid.Row="2" Text="系列 / 版本" Style="{StaticResource SecondaryTextStyle}" Margin="0,6,0,0" />
                  <TextBlock Grid.Row="2" Grid.Column="1" Margin="0,6,0,0"><Run Text="{Binding Workspace.SelectedIdentification.ProductFamily, Mode=OneWay, TargetNullValue=未识别}" /><Run Text="  " /><Run Text="{Binding Workspace.SelectedIdentification.Version, Mode=OneWay, TargetNullValue=未识别}" /></TextBlock>
                  <TextBlock Grid.Row="3" Text="可信度 / 时间" Style="{StaticResource SecondaryTextStyle}" Margin="0,6,0,0" />
                  <TextBlock Grid.Row="3" Grid.Column="1" Margin="0,6,0,0"><Run Text="{Binding Workspace.SelectedIdentification.Confidence, Mode=OneWay, StringFormat={}{0:P0}}" /><Run Text="  " /><Run Text="{Binding Workspace.SelectedIdentificationRecordedAtText, Mode=OneWay}" /></TextBlock>
                  <TextBlock Grid.Row="4" Text="识别依据" Style="{StaticResource SecondaryTextStyle}" Margin="0,6,0,0" />
                  <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding Workspace.SelectedIdentification.Evidence}" TextWrapping="Wrap" Margin="0,6,0,0" />
                  <TextBlock Grid.Row="5" Text="确认方式" Style="{StaticResource SecondaryTextStyle}" Margin="0,6,0,0" />
                  <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding Workspace.SelectedIdentification.ConfirmationSource, TargetNullValue=已验证规则自动识别}" TextWrapping="Wrap" Margin="0,6,0,0" />
                </Grid>
              </StackPanel>
            </Grid>
          </Border>
        </Grid>

        <Grid x:Name="DeviceWizardPanel" Margin="24">
          <Grid.Style>
            <Style TargetType="Grid">
              <Setter Property="Visibility" Value="Collapsed" />
              <Style.Triggers><DataTrigger Binding="{Binding DeviceEditor.IsOpen}" Value="True"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers>
            </Style>
          </Grid.Style>
          <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="78" /><RowDefinition Height="*" /><RowDefinition Height="64" /></Grid.RowDefinitions>
          <StackPanel Grid.Row="0">
            <TextBlock Text="设备管理  ›  添加设备" Style="{StaticResource SecondaryTextStyle}" FontSize="12" />
            <TextBlock Text="添加设备" Style="{StaticResource PageTitleStyle}" />
          </StackPanel>

          <Grid Grid.Row="1" MaxWidth="820" HorizontalAlignment="Center">
            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal">
              <Border Width="32" Height="32" CornerRadius="16">
                <Border.Style><Style TargetType="Border"><Setter Property="Background" Value="{DynamicResource Brush.SurfaceMuted}" /><Style.Triggers><DataTrigger Binding="{Binding DeviceEditor.Step}" Value="{x:Static viewModels:DeviceEditorStep.BasicInformation}"><Setter Property="Background" Value="{DynamicResource Brush.Accent}" /></DataTrigger></Style.Triggers></Style></Border.Style>
                <TextBlock Text="01" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"><TextBlock.Style><Style TargetType="TextBlock"><Setter Property="Foreground" Value="{DynamicResource Brush.TextSecondary}" /><Style.Triggers><DataTrigger Binding="{Binding DeviceEditor.Step}" Value="{x:Static viewModels:DeviceEditorStep.BasicInformation}"><Setter Property="Foreground" Value="White" /></DataTrigger></Style.Triggers></Style></TextBlock.Style></TextBlock>
              </Border>
              <StackPanel Margin="10,0,0,0"><TextBlock Text="基本信息" FontWeight="SemiBold" /><TextBlock Text="设备与类型" Style="{StaticResource SecondaryTextStyle}" FontSize="10.5" /></StackPanel>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
              <Border Width="32" Height="32" CornerRadius="16">
                <Border.Style><Style TargetType="Border"><Setter Property="Background" Value="{DynamicResource Brush.SurfaceMuted}" /><Style.Triggers><DataTrigger Binding="{Binding DeviceEditor.Step}" Value="{x:Static viewModels:DeviceEditorStep.ConnectionConfiguration}"><Setter Property="Background" Value="{DynamicResource Brush.Accent}" /></DataTrigger></Style.Triggers></Style></Border.Style>
                <TextBlock Text="02" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"><TextBlock.Style><Style TargetType="TextBlock"><Setter Property="Foreground" Value="{DynamicResource Brush.TextSecondary}" /><Style.Triggers><DataTrigger Binding="{Binding DeviceEditor.Step}" Value="{x:Static viewModels:DeviceEditorStep.ConnectionConfiguration}"><Setter Property="Foreground" Value="White" /></DataTrigger></Style.Triggers></Style></TextBlock.Style></TextBlock>
              </Border>
              <StackPanel Margin="10,0,0,0"><TextBlock Text="连接配置" FontWeight="SemiBold" /><TextBlock Text="协议与凭据" Style="{StaticResource SecondaryTextStyle}" FontSize="10.5" /></StackPanel>
            </StackPanel>
            <StackPanel Grid.Column="2" Orientation="Horizontal">
              <Border Width="32" Height="32" CornerRadius="16">
                <Border.Style><Style TargetType="Border"><Setter Property="Background" Value="{DynamicResource Brush.SurfaceMuted}" /><Style.Triggers><DataTrigger Binding="{Binding DeviceEditor.Step}" Value="{x:Static viewModels:DeviceEditorStep.SaveAndTest}"><Setter Property="Background" Value="{DynamicResource Brush.Accent}" /></DataTrigger></Style.Triggers></Style></Border.Style>
                <TextBlock Text="03" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"><TextBlock.Style><Style TargetType="TextBlock"><Setter Property="Foreground" Value="{DynamicResource Brush.TextSecondary}" /><Style.Triggers><DataTrigger Binding="{Binding DeviceEditor.Step}" Value="{x:Static viewModels:DeviceEditorStep.SaveAndTest}"><Setter Property="Foreground" Value="White" /></DataTrigger></Style.Triggers></Style></TextBlock.Style></TextBlock>
              </Border>
              <StackPanel Margin="10,0,0,0"><TextBlock Text="安全确认" FontWeight="SemiBold" /><TextBlock Text="保存后再探测" Style="{StaticResource SecondaryTextStyle}" FontSize="10.5" /></StackPanel>
            </StackPanel>
          </Grid>

          <Grid Grid.Row="2">
            <Grid.ColumnDefinitions><ColumnDefinition Width="2*" /><ColumnDefinition Width="16" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
            <Border Grid.Column="0" Style="{StaticResource FluentCardStyle}" Padding="24">
              <Grid>
                <StackPanel>
                  <StackPanel.Style><Style TargetType="StackPanel"><Setter Property="Visibility" Value="Collapsed" /><Style.Triggers><DataTrigger Binding="{Binding DeviceEditor.Step}" Value="{x:Static viewModels:DeviceEditorStep.BasicInformation}"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers></Style></StackPanel.Style>
                  <TextBlock Text="01  基本信息" Style="{StaticResource SectionTitleStyle}" />
                  <TextBlock Text="录入用户明确授权的设备，不会自动扫描客户网络。" Style="{StaticResource SecondaryTextStyle}" Margin="0,0,0,18" />
                  <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="16" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><StackPanel><TextBlock Text="设备名称 *" /><TextBox Text="{Binding DeviceEditor.DisplayName, UpdateSourceTrigger=PropertyChanged}" automation:AutomationProperties.Name="设备名称" /></StackPanel><StackPanel Grid.Column="2"><TextBlock Text="主机地址或 IP *" /><TextBox Text="{Binding DeviceEditor.Host, UpdateSourceTrigger=PropertyChanged}" automation:AutomationProperties.Name="主机地址或 IP" /></StackPanel></Grid>
                  <TextBlock Text="设备类别" />
                  <ComboBox SelectedValue="{Binding DeviceEditor.Category, Mode=TwoWay}" SelectedValuePath="Tag" Margin="0,4,0,12">
                    <ComboBoxItem Content="自动识别（推荐）" Tag="{x:Static core:TargetCategory.Automatic}" />
                    <ComboBoxItem Content="网络设备" Tag="{x:Static core:TargetCategory.NetworkDevice}" />
                    <ComboBoxItem Content="服务器" Tag="{x:Static core:TargetCategory.Server}" />
                    <ComboBoxItem Content="数据库" Tag="{x:Static core:TargetCategory.Database}" />
                    <ComboBoxItem Content="中间件" Tag="{x:Static core:TargetCategory.Middleware}" />
                    <ComboBoxItem Content="安全设备" Tag="{x:Static core:TargetCategory.SecurityDevice}" />
                  </ComboBox>
                  <Border Background="{DynamicResource Brush.WarningBackground}" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                    <Border.Style>
                      <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                          <DataTrigger Binding="{Binding DeviceEditor.Category}" Value="{x:Static core:TargetCategory.NetworkDevice}">
                            <Setter Property="Visibility" Value="Visible" />
                          </DataTrigger>
                        </Style.Triggers>
                      </Style>
                    </Border.Style>
                    <TextBlock Text="设备类别不会决定厂商命令。保存后必须在采集页明确选择已验证的厂商适配器；未选择时不会连接或执行命令。" Foreground="{DynamicResource Brush.WarningText}" TextWrapping="Wrap" />
                  </Border>
                </StackPanel>

                <StackPanel>
                  <StackPanel.Style><Style TargetType="StackPanel"><Setter Property="Visibility" Value="Collapsed" /><Style.Triggers><DataTrigger Binding="{Binding DeviceEditor.Step}" Value="{x:Static viewModels:DeviceEditorStep.ConnectionConfiguration}"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers></Style></StackPanel.Style>
                  <TextBlock Text="02  连接配置" Style="{StaticResource SectionTitleStyle}" />
                  <TextBlock Text="首版先接通 SSH；其他方式后续按插件启用，不会影响核心软件启动。" Style="{StaticResource SecondaryTextStyle}" Margin="0,0,0,18" />
                  <Border Background="{DynamicResource Brush.AccentSoft}" BorderBrush="{DynamicResource Brush.Accent}" BorderThickness="1" CornerRadius="7" Padding="14" Margin="0,0,0,16"><StackPanel Orientation="Horizontal"><TextBlock Text="&#xE756;" Style="{StaticResource FluentSymbolStyle}" Foreground="{DynamicResource Brush.Accent}" FontSize="19" Width="42" /><StackPanel><TextBlock Text="SSH" FontWeight="SemiBold" /><TextBlock Text="加密连接 · 首次必须确认主机指纹" Style="{StaticResource SecondaryTextStyle}" FontSize="11" /></StackPanel></StackPanel></Border>
                  <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="16" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><StackPanel><TextBlock Text="SSH 用户名 *" /><TextBox Text="{Binding DeviceEditor.UserName, UpdateSourceTrigger=PropertyChanged}" automation:AutomationProperties.Name="SSH 用户名" /></StackPanel><StackPanel Grid.Column="2"><TextBlock Text="端口 *" /><TextBox Text="{Binding DeviceEditor.PortText, UpdateSourceTrigger=PropertyChanged}" automation:AutomationProperties.Name="SSH 端口" /></StackPanel></Grid>
                  <TextBlock Text="身份验证方式 *" />
                  <ComboBox x:Name="DeviceAuthenticationSelector"
                            SelectedValue="{Binding DeviceEditor.AuthenticationMethod, Mode=TwoWay}"
                            SelectedValuePath="Tag"
                            SelectionChanged="DeviceAuthentication_Changed"
                            Margin="0,4,0,12"
                            automation:AutomationProperties.Name="SSH 身份验证方式">
                    <ComboBoxItem Content="密码验证" Tag="{x:Static core:SshAuthenticationMethod.Password}" />
                    <ComboBoxItem Content="PuTTY PPK 私钥" Tag="{x:Static core:SshAuthenticationMethod.PrivateKey}" />
                  </ComboBox>
                  <StackPanel>
                    <StackPanel.Style>
                      <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers><DataTrigger Binding="{Binding DeviceEditor.IsPasswordAuthentication}" Value="True"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers>
                      </Style>
                    </StackPanel.Style>
                    <TextBlock Text="登录密码 *" />
                    <PasswordBox x:Name="DevicePasswordBox" PasswordChanged="DevicePassword_Changed" automation:AutomationProperties.Name="连接密码" />
                    <TextBlock Text="密码仅在保存时复制到安全缓冲区，随后使用当前 Windows 用户的 DPAPI 加密。" Style="{StaticResource SecondaryTextStyle}" FontSize="11" />
                  </StackPanel>
                  <StackPanel>
                    <StackPanel.Style>
                      <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers><DataTrigger Binding="{Binding DeviceEditor.IsPrivateKeyAuthentication}" Value="True"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers>
                      </Style>
                    </StackPanel.Style>
                    <TextBlock Text="PuTTY PPK 私钥 *" />
                    <Grid Margin="0,4,0,0">
                      <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                      <Border Background="{DynamicResource Brush.SurfaceSubtle}" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1" CornerRadius="6" Padding="12,8" Margin="0,0,10,0">
                        <TextBlock Text="{Binding DeviceEditor.PrivateKeyFileName, TargetNullValue=尚未选择私钥文件, FallbackValue=尚未选择私钥文件}" TextTrimming="CharacterEllipsis" ToolTip="{Binding DeviceEditor.PrivateKeyFileName}" automation:AutomationProperties.Name="已选择的私钥安全文件名" />
                      </Border>
                      <Button Grid.Column="1" Content="选择 PPK 文件" Style="{StaticResource FluentSecondaryButtonStyle}" Click="SelectPrivateKey_Click" automation:AutomationProperties.Name="选择 PuTTY PPK 私钥文件" />
                    </Grid>
                    <TextBlock Text="仅接受不超过 256 KB、严格 UTF-8 编码且未设置口令的 PuTTY PPK v2/v3；界面和项目数据只保留文件名，不保存原始路径。" Style="{StaticResource SecondaryTextStyle}" FontSize="11" TextWrapping="Wrap" Margin="0,5,0,0" />
                  </StackPanel>
                </StackPanel>

                <StackPanel>
                  <StackPanel.Style><Style TargetType="StackPanel"><Setter Property="Visibility" Value="Collapsed" /><Style.Triggers><DataTrigger Binding="{Binding DeviceEditor.Step}" Value="{x:Static viewModels:DeviceEditorStep.SaveAndTest}"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers></Style></StackPanel.Style>
                  <TextBlock Text="03  保存与连接测试" Style="{StaticResource SectionTitleStyle}" />
                  <TextBlock Text="请确认设备资料。保存后进入：自动探测指纹 → 人工确认 → 无命令测试登录。" Style="{StaticResource SecondaryTextStyle}" Margin="0,0,0,20" />
                  <Border Background="{DynamicResource Brush.SurfaceSubtle}" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1" CornerRadius="7" Padding="18">
                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="*" />
                      </Grid.ColumnDefinitions>
                      <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                      </Grid.RowDefinitions>
                      <TextBlock Text="设备名称" Style="{StaticResource SecondaryTextStyle}" />
                      <TextBlock Grid.Column="1" Text="{Binding DeviceEditor.DisplayName}" FontWeight="SemiBold" />
                      <TextBlock Grid.Row="1" Text="主机地址" Style="{StaticResource SecondaryTextStyle}" Margin="0,10,0,0" />
                      <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding DeviceEditor.Host}" Margin="0,10,0,0" />
                      <TextBlock Grid.Row="2" Text="SSH 账户" Style="{StaticResource SecondaryTextStyle}" Margin="0,10,0,0" />
                      <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding DeviceEditor.UserName}" Margin="0,10,0,0" />
                      <TextBlock Grid.Row="3" Text="设备类别" Style="{StaticResource SecondaryTextStyle}" Margin="0,10,0,0" />
                      <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding DeviceEditor.Category, Converter={StaticResource DeviceMetadataConverter}}" Margin="0,10,0,0" />
                      <TextBlock Grid.Row="4" Text="身份验证" Style="{StaticResource SecondaryTextStyle}" Margin="0,10,0,0" />
                      <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding DeviceEditor.AuthenticationMethod, Converter={StaticResource DeviceMetadataConverter}}" Margin="0,10,0,0" />
                      <TextBlock Grid.Row="5" Text="私钥文件" Margin="0,10,0,0">
                        <TextBlock.Style>
                          <Style TargetType="TextBlock" BasedOn="{StaticResource SecondaryTextStyle}">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                              <DataTrigger Binding="{Binding DeviceEditor.IsPrivateKeyAuthentication}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                              </DataTrigger>
                            </Style.Triggers>
                          </Style>
                        </TextBlock.Style>
                      </TextBlock>
                      <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding DeviceEditor.PrivateKeyFileName}" Margin="0,10,0,0">
                        <TextBlock.Style>
                          <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                              <DataTrigger Binding="{Binding DeviceEditor.IsPrivateKeyAuthentication}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                              </DataTrigger>
                            </Style.Triggers>
                          </Style>
                        </TextBlock.Style>
                      </TextBlock>
                    </Grid>
                  </Border>
                </StackPanel>
              </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource FluentCardStyle}" Background="{DynamicResource Brush.SurfaceSubtle}" Padding="0" ClipToBounds="True">
              <Grid>
                <Grid.RowDefinitions><RowDefinition Height="110" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                <Image Source="/AssessmentTool.App;component/Assets/network-security-hero.png" Stretch="UniformToFill" />
                <StackPanel Grid.Row="1" Margin="20,18,20,20">
                  <StackPanel Orientation="Horizontal"><TextBlock Text="&#xEA18;" Style="{StaticResource FluentSymbolStyle}" Foreground="{DynamicResource Brush.Accent}" FontSize="18" Margin="0,0,9,0" /><TextBlock Text="安全合规说明" Foreground="{DynamicResource Brush.Accent}" FontWeight="SemiBold" FontSize="17" /></StackPanel>
                  <Grid Margin="0,18,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="28" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><TextBlock Text="&#xE72E;" Style="{StaticResource FluentSymbolStyle}" Foreground="{DynamicResource Brush.Accent}" /><TextBlock Grid.Column="1" Text="仅操作手动添加并获得明确授权的设备。" TextWrapping="Wrap" /></Grid>
                  <Grid Margin="0,14,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="28" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><TextBlock Text="&#xE83D;" Style="{StaticResource FluentSymbolStyle}" Foreground="{DynamicResource Brush.Accent}" /><TextBlock Grid.Column="1" Text="自动采集只能执行已校验的只读命令。" TextWrapping="Wrap" /></Grid>
                  <Grid Margin="0,14,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="28" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><TextBlock Text="&#xE8D7;" Style="{StaticResource FluentSymbolStyle}" Foreground="{DynamicResource Brush.Accent}" /><TextBlock Grid.Column="1" Text="首次 SSH 连接必须由测评人员确认主机指纹。" TextWrapping="Wrap" /></Grid>
                  <Grid Margin="0,14,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="28" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><TextBlock Text="&#xE77B;" Style="{StaticResource FluentSymbolStyle}" Foreground="{DynamicResource Brush.Accent}" /><TextBlock Grid.Column="1" Text="建议使用只读或最小权限测评账户。" TextWrapping="Wrap" /></Grid>
                  <Border Background="{DynamicResource Brush.InfoBackground}" BorderBrush="{DynamicResource Brush.Accent}" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,20,0,0"><TextBlock Text="保存设备只写入本机加密资料，不会连接客户设备，也不会执行命令。" TextWrapping="Wrap" /></Border>
                </StackPanel>
              </Grid>
            </Border>
          </Grid>

          <Border Grid.Row="3" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="0,1,0,0" Padding="0,12,0,0">
            <Grid>
              <TextBlock Text="{Binding DeviceEditor.ValidationMessage}" Style="{StaticResource SecondaryTextStyle}" VerticalAlignment="Center" />
              <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="取消" Style="{StaticResource FluentSecondaryButtonStyle}" Click="CancelDeviceWizard_Click" />
                <Button Content="上一步" Click="DeviceWizardBack_Click">
                  <Button.Style><Style TargetType="Button" BasedOn="{StaticResource FluentSecondaryButtonStyle}"><Setter Property="Visibility" Value="Visible" /><Style.Triggers><DataTrigger Binding="{Binding DeviceEditor.Step}" Value="{x:Static viewModels:DeviceEditorStep.BasicInformation}"><Setter Property="Visibility" Value="Collapsed" /></DataTrigger></Style.Triggers></Style></Button.Style>
                </Button>
                <Button Content="下一步" IsEnabled="{Binding DeviceEditor.CanContinue}" Click="DeviceWizardNext_Click">
                  <Button.Style><Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}"><Setter Property="Visibility" Value="Visible" /><Style.Triggers><DataTrigger Binding="{Binding DeviceEditor.Step}" Value="{x:Static viewModels:DeviceEditorStep.SaveAndTest}"><Setter Property="Visibility" Value="Collapsed" /></DataTrigger></Style.Triggers></Style></Button.Style>
                </Button>
                <Button Content="保存设备" IsEnabled="{Binding DeviceEditor.CanContinue}" Click="SaveDevice_Click" automation:AutomationProperties.Name="使用 DPAPI 加密保存设备">
                  <Button.Style><Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}"><Setter Property="Visibility" Value="Collapsed" /><Style.Triggers><DataTrigger Binding="{Binding DeviceEditor.Step}" Value="{x:Static viewModels:DeviceEditorStep.SaveAndTest}"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers></Style></Button.Style>
                </Button>
              </StackPanel>
            </Grid>
          </Border>
        </Grid>
        </Grid>
      </TabItem>

      <TabItem Header="采集任务">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
          <StackPanel Margin="28" MaxWidth="900" HorizontalAlignment="Left">
            <TextBlock Text="只读采集任务" Style="{StaticResource PageTitleStyle}" />
            <TextBlock Text="自动采集区不提供自由命令输入，只执行已验证命令包。" Style="{StaticResource SecondaryTextStyle}" Margin="0,0,0,20" />
            <Border Style="{StaticResource CardStyle}" Background="{DynamicResource Brush.WarningBackground}">
              <TextBlock Text="当前支持已完成指纹确认和无命令登录测试的 SSH Linux、Windows Server 成员服务器、固定路径 Nginx，以及明确选择并人工确认的华为 VRP、H3C Comware 网络设备；所有类型都必须先选择匹配的只读适配器，Windows 目标仍需管理员确认不是域控制器。" Foreground="{DynamicResource Brush.WarningText}" TextWrapping="Wrap" />
            </Border>
            <Border Style="{StaticResource CardStyle}">
              <StackPanel>
                <TextBlock Text="{Binding Collection.State, StringFormat=当前状态：{0}}" Style="{StaticResource SectionTitleStyle}" />
                <StackPanel Margin="0,10,0,6">
                  <StackPanel.Style>
                    <Style TargetType="StackPanel">
                      <Setter Property="Visibility" Value="Collapsed" />
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding Collection.IsAdapterSelectionVisible}" Value="True">
                          <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </StackPanel.Style>
                  <TextBlock Text="采集适配器 *" FontWeight="SemiBold" />
                  <ComboBox ItemsSource="{Binding Collection.AdapterOptions}"
                            SelectedItem="{Binding Collection.SelectedAdapterOption, Mode=TwoWay}"
                            DisplayMemberPath="DisplayName"
                            automation:AutomationProperties.Name="采集适配器"
                            Margin="0,5,0,6" />
                  <TextBlock Text="{Binding Collection.AdapterScopeNotice, Mode=OneWay}"
                             Style="{StaticResource SecondaryTextStyle}"
                             TextWrapping="Wrap" />
                </StackPanel>
                <TextBlock Text="{Binding Collection.ProgressMessage, TargetNullValue=等待开始}" TextWrapping="Wrap" />
                <TextBlock Text="{Binding Collection.CurrentCommand, StringFormat=当前命令编号：{0}, TargetNullValue=尚未执行命令}" Style="{StaticResource SecondaryTextStyle}" Margin="0,6" />
                <ProgressBar Height="8"
                             Minimum="0"
                             Maximum="{Binding Collection.TotalCommandCount, Mode=OneWay}"
                             Value="{Binding Collection.CompletedCommandCount, Mode=OneWay}"
                             Margin="0,10" />
                <TextBlock Text="{Binding Collection.CompletedCommandCount, StringFormat=已完成 {0} 条}" />
                <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                  <Button Content="开始只读采集" Command="{Binding Collection.StartCommand}" automation:AutomationProperties.Name="开始已验证只读采集" />
                  <Button Content="安全停止" Command="{Binding Collection.StopCommand}" automation:AutomationProperties.Name="安全停止采集" />
                </StackPanel>
              </StackPanel>
            </Border>

            <Border Style="{StaticResource CardStyle}" automation:AutomationProperties.Name="采集任务历史">
              <StackPanel>
                <Grid Margin="0,0,0,12">
                  <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                  <StackPanel>
                    <TextBlock Text="任务历史" Style="{StaticResource SectionTitleStyle}" />
                    <TextBlock Text="{Binding TaskHistory.StatusMessage}" Style="{StaticResource SecondaryTextStyle}" TextWrapping="Wrap" />
                  </StackPanel>
                  <Button Grid.Column="1" Content="刷新" Command="{Binding TaskHistory.RefreshCommand}" Margin="12,0,0,0" />
                </Grid>
                <ItemsControl ItemsSource="{Binding TaskHistory.Items}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border Background="{DynamicResource Brush.SurfaceSubtle}"
                              BorderBrush="{DynamicResource Brush.Border}"
                              BorderThickness="1"
                              CornerRadius="8"
                              Padding="14"
                              Margin="0,0,0,9">
                        <Grid>
                          <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                          <StackPanel>
                            <TextBlock Text="{Binding Host, StringFormat=目标主机：{0}}" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding StatusDescription}" Style="{StaticResource SecondaryTextStyle}" TextWrapping="Wrap" Margin="0,4,14,0" />
                            <StackPanel Orientation="Horizontal" Margin="0,7,0,0">
                              <TextBlock Text="{Binding CommandCount, StringFormat=锁定命令：{0} 条}" Style="{StaticResource SecondaryTextStyle}" />
                              <TextBlock Text="{Binding LastUpdatedAt, StringFormat=最后更新：{0:yyyy-MM-dd HH:mm:ss}}" Style="{StaticResource SecondaryTextStyle}" Margin="18,0,0,0" />
                            </StackPanel>
                          </StackPanel>
                          <Border Grid.Column="1" Background="{DynamicResource Brush.AccentSoft}" CornerRadius="11" Padding="10,4" VerticalAlignment="Top">
                            <TextBlock Text="{Binding StatusText}" Foreground="{DynamicResource Brush.Accent}" FontWeight="SemiBold" />
                          </Border>
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
                <Border Background="{DynamicResource Brush.ErrorBackground}" BorderBrush="{DynamicResource Brush.Error}" BorderThickness="1" CornerRadius="8" Padding="12">
                  <Border.Style>
                    <Style TargetType="Border">
                      <Setter Property="Visibility" Value="Collapsed" />
                      <Style.Triggers><DataTrigger Binding="{Binding TaskHistory.State}" Value="Failed"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers>
                    </Style>
                  </Border.Style>
                  <StackPanel>
                    <TextBlock Text="{Binding TaskHistory.WhatHappened}" Foreground="{DynamicResource Brush.Error}" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding TaskHistory.PossibleCause}" TextWrapping="Wrap" Margin="0,4,0,0" />
                    <TextBlock Text="{Binding TaskHistory.HowToFix}" TextWrapping="Wrap" Margin="0,4,0,0" />
                  </StackPanel>
                </Border>
              </StackPanel>
            </Border>

            <Border automation:AutomationProperties.Name="数据库候选人工确认">
              <Border.Style>
                <Style TargetType="Border" BasedOn="{StaticResource CardStyle}">
                  <Setter Property="Visibility" Value="Collapsed" />
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding Collection.IsDatabaseConfirmationVisible, Mode=OneWay}" Value="True">
                      <Setter Property="Visibility" Value="Visible" />
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </Border.Style>
              <StackPanel>
                <Grid Margin="0,0,0,6">
                  <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                  <StackPanel>
                    <TextBlock Text="发现数据库实例，需要人工确认" Style="{StaticResource SectionTitleStyle}" />
                    <TextBlock Text="请根据实例名称、安装方式和发现依据选择正确结果。无法判断时不要确认，可保留当前记录后人工核查。"
                               Style="{StaticResource SecondaryTextStyle}"
                               TextWrapping="Wrap" />
                    <TextBlock Text="{Binding Collection.ProgressMessage, Mode=OneWay}"
                               Foreground="{DynamicResource Brush.Accent}"
                               Margin="0,5,0,0"
                               TextWrapping="Wrap" />
                  </StackPanel>
                  <Border Grid.Column="1"
                          Background="{DynamicResource Brush.WarningBackground}"
                          BorderBrush="{DynamicResource Brush.Warning}"
                          BorderThickness="1"
                          CornerRadius="12"
                          Padding="10,4"
                          VerticalAlignment="Top">
                    <TextBlock Text="需要人工确认" Foreground="{DynamicResource Brush.WarningText}" FontSize="12" />
                  </Border>
                </Grid>

                <Border Background="{DynamicResource Brush.InfoBackground}"
                        BorderBrush="{DynamicResource Brush.Accent}"
                        BorderThickness="3,0,0,0"
                        CornerRadius="7"
                        Padding="14,11"
                        Margin="0,10,0,14">
                  <StackPanel>
                    <TextBlock Text="安全边界" FontWeight="SemiBold" Foreground="{DynamicResource Brush.Accent}" />
                    <TextBlock Text="此操作仅确认主机侧只读发现结果，本阶段不执行 SQL，也不建立数据库直连。"
                               TextWrapping="Wrap"
                               Margin="0,4,0,0" />
                  </StackPanel>
                </Border>

                <ItemsControl ItemsSource="{Binding Collection.DatabaseCandidates}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border Background="{DynamicResource Brush.SurfaceSubtle}"
                              BorderBrush="{DynamicResource Brush.Border}"
                              BorderThickness="1"
                              CornerRadius="8"
                              Padding="16"
                              Margin="0,0,0,10">
                        <Grid>
                          <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                          <StackPanel Margin="0,0,20,0">
                            <StackPanel Orientation="Horizontal">
                              <TextBlock Text="▰" Foreground="{DynamicResource Brush.Accent}" FontSize="16" Margin="0,0,9,0" VerticalAlignment="Center" />
                              <TextBlock Text="{Binding Product}" FontWeight="SemiBold" FontSize="17" VerticalAlignment="Center" />
                              <Border Background="{DynamicResource Brush.AccentSoft}" CornerRadius="10" Padding="8,2" Margin="10,0,0,0">
                                <TextBlock FontSize="11" Foreground="{DynamicResource Brush.Accent}">
                                  <Run Text="可信度 " /><Run Text="{Binding Confidence, Mode=OneWay, StringFormat={}{0:P0}}" />
                                </TextBlock>
                              </Border>
                            </StackPanel>

                            <Grid Margin="25,11,0,0">
                              <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                              </Grid.ColumnDefinitions>
                              <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                              <TextBlock Text="实例名称" Style="{StaticResource SecondaryTextStyle}" />
                              <TextBlock Grid.Column="1" Text="{Binding InstanceName}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                              <TextBlock Grid.Column="2" Text="安装方式" Style="{StaticResource SecondaryTextStyle}" />
                              <TextBlock Grid.Column="3" Text="{Binding InstallationType}" FontWeight="SemiBold" />
                              <TextBlock Grid.Row="1" Text="版本" Style="{StaticResource SecondaryTextStyle}" Margin="0,7,0,0" />
                              <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Version, TargetNullValue=未识别}" Margin="0,7,0,0" />
                              <TextBlock Grid.Row="1" Grid.Column="2" Text="端口依据" Style="{StaticResource SecondaryTextStyle}" Margin="0,7,0,0" />
                              <TextBlock Grid.Row="1" Grid.Column="3" Text="{Binding PortEvidence, TargetNullValue=未发现}" Margin="0,7,0,0" TextTrimming="CharacterEllipsis" />
                            </Grid>

                            <Border Background="{DynamicResource Brush.Surface}"
                                    BorderBrush="{DynamicResource Brush.Border}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="10,8"
                                    Margin="25,12,0,0">
                              <TextBlock Text="{Binding Evidence, StringFormat=发现依据：{0}}" TextWrapping="Wrap" />
                            </Border>
                          </StackPanel>
                          <Button Grid.Column="1"
                                  Content="确认此数据库实例"
                                  Style="{StaticResource FluentPrimaryButtonStyle}"
                                  Command="{Binding DataContext.Collection.ConfirmDatabaseCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                  CommandParameter="{Binding}"
                                  VerticalAlignment="Center"
                                  automation:AutomationProperties.Name="仅确认发现的数据库实例，不执行 SQL" />
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </Border>

            <Border automation:AutomationProperties.Name="数据库与中间件候选人工确认">
              <Border.Style>
                <Style TargetType="Border" BasedOn="{StaticResource CardStyle}">
                  <Setter Property="Visibility" Value="Collapsed" />
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding Collection.IsHostSoftwareConfirmationVisible, Mode=OneWay}" Value="True">
                      <Setter Property="Visibility" Value="Visible" />
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </Border.Style>
              <StackPanel>
                <Grid Margin="0,0,0,6">
                  <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                  <StackPanel>
                    <TextBlock Text="发现数据库或中间件，需要人工确认" Style="{StaticResource SectionTitleStyle}" />
                    <TextBlock Text="结果来自已保存的只读主机命令。请逐项确认；不是本次测评目标的实例可直接排除。"
                               Style="{StaticResource SecondaryTextStyle}"
                               TextWrapping="Wrap" />
                    <TextBlock Text="{Binding Collection.ProgressMessage, Mode=OneWay}"
                               Foreground="{DynamicResource Brush.Accent}"
                               Margin="0,5,0,0"
                               TextWrapping="Wrap" />
                  </StackPanel>
                  <Border Grid.Column="1"
                          Background="{DynamicResource Brush.WarningBackground}"
                          BorderBrush="{DynamicResource Brush.Warning}"
                          BorderThickness="1"
                          CornerRadius="12"
                          Padding="10,4"
                          VerticalAlignment="Top">
                    <TextBlock Text="逐项人工确认" Foreground="{DynamicResource Brush.WarningText}" FontSize="12" />
                  </Border>
                </Grid>

                <Border Background="{DynamicResource Brush.InfoBackground}"
                        BorderBrush="{DynamicResource Brush.Accent}"
                        BorderThickness="3,0,0,0"
                        CornerRadius="7"
                        Padding="14,11"
                        Margin="0,10,0,14">
                  <TextBlock Text="安全边界：仅保存人工确认或排除决议，不执行 SQL、不连接实例，也不修改客户设备。"
                             TextWrapping="Wrap" />
                </Border>

                <ItemsControl ItemsSource="{Binding Collection.HostSoftwareCandidates, Mode=OneWay}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border Background="{DynamicResource Brush.SurfaceSubtle}"
                              BorderBrush="{DynamicResource Brush.Border}"
                              BorderThickness="1"
                              CornerRadius="8"
                              Padding="16"
                              Margin="0,0,0,10">
                        <Grid>
                          <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                          <StackPanel Margin="0,0,20,0">
                            <StackPanel Orientation="Horizontal">
                              <TextBlock Text="▰" Foreground="{DynamicResource Brush.Accent}" FontSize="16" Margin="0,0,9,0" />
                              <TextBlock Text="{Binding Product, Mode=OneWay}" FontWeight="SemiBold" FontSize="17" />
                              <Border Background="{DynamicResource Brush.AccentSoft}" CornerRadius="10" Padding="8,2" Margin="10,0,0,0">
                                <StackPanel Orientation="Horizontal">
                                  <TextBlock FontSize="11" Foreground="{DynamicResource Brush.Accent}">
                                    <TextBlock.Style>
                                      <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="中间件" />
                                        <Style.Triggers>
                                          <DataTrigger Binding="{Binding Category}" Value="{x:Static storage:HostSoftwareCategory.Database}">
                                            <Setter Property="Text" Value="数据库" />
                                          </DataTrigger>
                                        </Style.Triggers>
                                      </Style>
                                    </TextBlock.Style>
                                  </TextBlock>
                                  <TextBlock Text=" · " FontSize="11" Foreground="{DynamicResource Brush.Accent}" />
                                  <TextBlock Text="{Binding Confidence, Mode=OneWay, StringFormat={}{0:P0}}" FontSize="11" Foreground="{DynamicResource Brush.Accent}" />
                                </StackPanel>
                              </Border>
                            </StackPanel>

                            <Grid Margin="25,11,0,0">
                              <Grid.ColumnDefinitions><ColumnDefinition Width="110" /><ColumnDefinition Width="*" /><ColumnDefinition Width="110" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                              <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                              <TextBlock Text="实例名称" Style="{StaticResource SecondaryTextStyle}" />
                              <TextBlock Grid.Column="1" Text="{Binding InstanceName, Mode=OneWay}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                              <TextBlock Grid.Column="2" Text="安装方式" Style="{StaticResource SecondaryTextStyle}" />
                              <TextBlock Grid.Column="3" FontWeight="SemiBold">
                                <TextBlock.Style>
                                  <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="本地服务或进程" />
                                    <Style.Triggers>
                                      <DataTrigger Binding="{Binding InstallationType}" Value="{x:Static storage:HostSoftwareInstallationType.Container}">
                                        <Setter Property="Text" Value="容器" />
                                      </DataTrigger>
                                    </Style.Triggers>
                                  </Style>
                                </TextBlock.Style>
                              </TextBlock>
                              <TextBlock Grid.Row="1" Text="版本" Style="{StaticResource SecondaryTextStyle}" Margin="0,7,0,0" />
                              <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Version, Mode=OneWay, TargetNullValue=未识别}" Margin="0,7,0,0" />
                              <TextBlock Grid.Row="1" Grid.Column="2" Text="端口依据" Style="{StaticResource SecondaryTextStyle}" Margin="0,7,0,0" />
                              <TextBlock Grid.Row="1" Grid.Column="3" Text="{Binding PortEvidence, Mode=OneWay, TargetNullValue=未发现}" Margin="0,7,0,0" TextTrimming="CharacterEllipsis" />
                            </Grid>

                            <Border Background="{DynamicResource Brush.Surface}"
                                    BorderBrush="{DynamicResource Brush.Border}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="10,8"
                                    Margin="25,12,0,0">
                              <TextBlock Text="{Binding Sources[0].Excerpt, Mode=OneWay, StringFormat=发现依据：{0}}" TextWrapping="Wrap" />
                            </Border>
                          </StackPanel>
                          <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <Button Content="确认此实例"
                                    Style="{StaticResource FluentPrimaryButtonStyle}"
                                    Command="{Binding DataContext.Collection.ConfirmHostSoftwareCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding}"
                                    MinWidth="118"
                                    Margin="0,0,0,8" />
                            <Button Content="不是本次目标"
                                    Command="{Binding DataContext.Collection.RejectHostSoftwareCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding}"
                                    MinWidth="118" />
                          </StackPanel>
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </Border>

            <Border automation:AutomationProperties.Name="数据库发现结果已确认">
              <Border.Style>
                <Style TargetType="Border" BasedOn="{StaticResource CardStyle}">
                  <Setter Property="Visibility" Value="Collapsed" />
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding Collection.State}" Value="DatabaseConfirmed">
                      <Setter Property="Visibility" Value="Visible" />
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </Border.Style>
              <StackPanel>
                <StackPanel Orientation="Horizontal">
                  <Border Width="34" Height="34" CornerRadius="17" Background="{DynamicResource Brush.SuccessBackground}" Margin="0,0,12,0">
                    <TextBlock Text="✓" Foreground="{DynamicResource Brush.Success}" FontWeight="Bold" FontSize="17" HorizontalAlignment="Center" VerticalAlignment="Center" />
                  </Border>
                  <StackPanel>
                    <TextBlock Text="主机软件发现结果已处理" Style="{StaticResource SectionTitleStyle}" Foreground="{DynamicResource Brush.Success}" />
                    <TextBlock Text="已保存数据库或中间件候选的人工决议，可继续查看本次主机采集证据。" Style="{StaticResource SecondaryTextStyle}" />
                  </StackPanel>
                </StackPanel>
                <Border Background="{DynamicResource Brush.SurfaceSubtle}"
                        BorderBrush="{DynamicResource Brush.Border}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="14"
                        Margin="0,14,0,12">
                  <Border.Style>
                    <Style TargetType="Border">
                      <Setter Property="Visibility" Value="Visible" />
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding Collection.SelectedDatabaseCandidate}" Value="{x:Null}">
                          <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </Border.Style>
                  <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="2*" /><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                    <StackPanel>
                      <TextBlock Text="数据库产品" Style="{StaticResource SecondaryTextStyle}" />
                      <TextBlock Text="{Binding Collection.SelectedDatabaseCandidate.Product}" FontWeight="SemiBold" FontSize="16" Margin="0,3,0,0" />
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                      <TextBlock Text="实例名称" Style="{StaticResource SecondaryTextStyle}" />
                      <TextBlock Text="{Binding Collection.SelectedDatabaseCandidate.InstanceName}" FontWeight="SemiBold" Margin="0,3,0,0" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                      <TextBlock Text="安装方式" Style="{StaticResource SecondaryTextStyle}" />
                      <TextBlock Text="{Binding Collection.SelectedDatabaseCandidate.InstallationType}" FontWeight="SemiBold" Margin="0,3,0,0" />
                    </StackPanel>
                  </Grid>
                </Border>
                <Border Background="{DynamicResource Brush.SuccessBackground}" CornerRadius="7" Padding="14,10">
                  <TextBlock Text="✓ 仅确认发现结果，本阶段未执行 SQL，也未建立数据库直连。"
                             Foreground="{DynamicResource Brush.Success}"
                             FontWeight="SemiBold"
                             TextWrapping="Wrap" />
                </Border>
              </StackPanel>
            </Border>

            <Border>
              <Border.Style>
                <Style TargetType="Border" BasedOn="{StaticResource CardStyle}">
                  <Setter Property="Visibility" Value="Collapsed" />
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding Collection.State}" Value="AwaitingConfirmation">
                      <Setter Property="Visibility" Value="Visible" />
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </Border.Style>
              <StackPanel>
                <TextBlock Text="识别结果需要人工确认" Style="{StaticResource SectionTitleStyle}" />
                <TextBlock Text="请根据识别依据选择正确对象；确认前不会执行完整采集命令。" Style="{StaticResource SecondaryTextStyle}" Margin="0,0,0,12" />
                <Border Background="{DynamicResource Brush.WarningBackground}" CornerRadius="7" Padding="12,9" Margin="0,0,0,12">
                  <Border.Style>
                    <Style TargetType="Border">
                      <Setter Property="Visibility" Value="Collapsed" />
                      <Style.Triggers><DataTrigger Binding="{Binding Collection.IsRecoveredIdentification}" Value="True"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers>
                    </Style>
                  </Border.Style>
                  <TextBlock Text="{Binding Collection.ProgressMessage}" Foreground="{DynamicResource Brush.Warning}" TextWrapping="Wrap" />
                </Border>
                <ItemsControl ItemsSource="{Binding Collection.DetectionCandidates}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,0,0,10">
                        <Grid>
                          <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                          <StackPanel>
                            <TextBlock FontWeight="SemiBold" FontSize="16">
                              <Run Text="{Binding Category, Mode=OneWay}" /><Run Text="  " /><Run Text="{Binding Vendor, Mode=OneWay, TargetNullValue=未知厂商}" />
                            </TextBlock>
                            <TextBlock Style="{StaticResource SecondaryTextStyle}" Margin="0,4,0,0">
                              <Run Text="产品系列：" /><Run Text="{Binding ProductFamily, Mode=OneWay, TargetNullValue=未知}" />
                              <Run Text="  版本：" /><Run Text="{Binding Version, Mode=OneWay, TargetNullValue=未知}" />
                            </TextBlock>
                            <TextBlock Text="{Binding Confidence, StringFormat=可信度：{0:P0}}" Style="{StaticResource SecondaryTextStyle}" />
                            <TextBlock Text="{Binding Evidence, StringFormat=识别依据：{0}}" TextWrapping="Wrap" Margin="0,6,16,0" />
                          </StackPanel>
                          <Button Grid.Column="1"
                                  Content="确认并重新识别"
                                  Command="{Binding DataContext.Collection.ConfirmDetectionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                  CommandParameter="{Binding}"
                                  VerticalAlignment="Center" />
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </Border>

            <Border>
              <Border.Style>
                <Style TargetType="Border" BasedOn="{StaticResource CardStyle}">
                  <Setter Property="Visibility" Value="Collapsed" />
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding Collection.State}" Value="Completed">
                      <Setter Property="Visibility" Value="Visible" />
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </Border.Style>
              <StackPanel>
                <TextBlock Text="采集与证据保存完成" Style="{StaticResource SectionTitleStyle}" Foreground="{DynamicResource Brush.Success}" />
                <TextBlock Text="原始输出、连续截图、SHA-256 和执行记录已保存。可前往证据页查看。" TextWrapping="Wrap" />
                <ItemsControl ItemsSource="{Binding Collection.CompletedCommands}" Margin="0,10,0,0">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <TextBlock Text="{Binding CommandId, StringFormat=✓ {0}}" Margin="0,2" />
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </Border>

            <Border BorderBrush="{DynamicResource Brush.Error}" BorderThickness="1" Background="{DynamicResource Brush.ErrorBackground}" CornerRadius="10" Padding="20">
              <Border.Style>
                <Style TargetType="Border">
                  <Setter Property="Visibility" Value="Visible" />
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding Collection.Error}" Value="{x:Null}"><Setter Property="Visibility" Value="Collapsed" /></DataTrigger>
                  </Style.Triggers>
                </Style>
              </Border.Style>
              <StackPanel automation:AutomationProperties.LiveSetting="Assertive">
                <TextBlock Text="{Binding Collection.Error.Summary}" Foreground="{DynamicResource Brush.Error}" FontWeight="SemiBold" FontSize="17" />
                <TextBlock Text="可能原因" FontWeight="SemiBold" Margin="0,10,0,2" />
                <TextBlock Text="{Binding Collection.Error.PossibleCause}" TextWrapping="Wrap" />
                <TextBlock Text="怎么处理" FontWeight="SemiBold" Margin="0,10,0,2" />
                <TextBlock Text="{Binding Collection.Error.RecommendedAction}" TextWrapping="Wrap" />
                <Expander Header="技术详情" Margin="0,10,0,0">
                  <TextBox Text="{Binding Collection.Error.TechnicalDetails, Mode=OneWay}" IsReadOnly="True" TextWrapping="Wrap" />
                </Expander>
              </StackPanel>
            </Border>
          </StackPanel>
        </ScrollViewer>
      </TabItem>

      <TabItem Header="证据">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
          <StackPanel Margin="28" MaxWidth="1100" HorizontalAlignment="Left">
            <Grid Margin="0,0,0,18">
              <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
              <StackPanel>
                <TextBlock Text="证据中心" Style="{StaticResource PageTitleStyle}" />
                <TextBlock Text="按当前项目查看人工确认审计、命令执行记录、原始输出索引、截图数量和 SHA-256 状态。" Style="{StaticResource SecondaryTextStyle}" />
              </StackPanel>
              <StackPanel Grid.Column="1">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,8">
                  <Button Content="导出离线报告" Command="{Binding EvidenceCenter.ExportReportCommand}" Style="{StaticResource FluentSecondaryButtonStyle}" Margin="0,0,8,0" automation:AutomationProperties.Name="只读复核后导出不含连接信息和输出正文的 HTML 离线报告" />
                  <Button Content="导出 JSON 清单" Command="{Binding EvidenceCenter.ExportManifestCommand}" Style="{StaticResource FluentSecondaryButtonStyle}" Margin="0,0,8,0" automation:AutomationProperties.Name="只读复核后导出不含凭据和正文的项目证据 JSON 清单" />
                  <Button Content="导出已验证证据包" Command="{Binding EvidenceCenter.ExportPackageCommand}" Style="{StaticResource FluentPrimaryButtonStyle}" automation:AutomationProperties.Name="再次校验哈希后将当前项目证据和清单导出为 ZIP" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                  <Button Content="打开证据目录" Command="{Binding EvidenceCenter.OpenFolderCommand}" Style="{StaticResource FluentSecondaryButtonStyle}" Margin="0,0,8,0" />
                  <Button Content="恢复待入库证据" Command="{Binding EvidenceCenter.RecoverCommand}" Style="{StaticResource FluentSecondaryButtonStyle}" Margin="0,0,8,0" automation:AutomationProperties.Name="校验执行清单和证据哈希后恢复本地索引" />
                  <Button Content="复核文件 SHA-256" Command="{Binding EvidenceCenter.VerifyCommand}" Style="{StaticResource FluentSecondaryButtonStyle}" Margin="0,0,8,0" />
                  <Button Content="刷新索引" Command="{Binding EvidenceCenter.RefreshCommand}" Style="{StaticResource FluentSecondaryButtonStyle}" />
                </StackPanel>
              </StackPanel>
            </Grid>
            <Border Style="{StaticResource CardStyle}">
              <StackPanel>
                <TextBlock Text="{Binding EvidenceCenter.State, StringFormat=当前状态：{0}}" Style="{StaticResource SectionTitleStyle}" />
                <TextBlock Text="普通刷新只核对 SQLite 索引，不读取证据文件；单击“复核文件 SHA-256”才会逐个只读计算原始输出和截图哈希。" Style="{StaticResource SecondaryTextStyle}" TextWrapping="Wrap" />
                <TextBlock Text="{Binding EvidenceCenter.VerificationSummary}" Margin="0,8,0,0" TextWrapping="Wrap" />
                <TextBlock Text="{Binding EvidenceCenter.RecoverySummary}" Margin="0,6,0,0" TextWrapping="Wrap" />
                <TextBlock Text="{Binding EvidenceCenter.ExportSummary}" Margin="0,6,0,0" TextWrapping="Wrap" />
                <TextBlock Text="{Binding EvidenceCenter.PackageExportSummary}" Margin="0,6,0,0" TextWrapping="Wrap" />
                <TextBlock Text="{Binding EvidenceCenter.ReportExportSummary}" Margin="0,6,0,0" TextWrapping="Wrap" />
              </StackPanel>
            </Border>

            <Border automation:AutomationProperties.Name="主机软件发现与人工决议审计历史">
              <Border.Style>
                <Style TargetType="Border" BasedOn="{StaticResource CardStyle}">
                  <Setter Property="Visibility" Value="Collapsed" />
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding EvidenceCenter.HasHostSoftwareDiscoveries}" Value="True">
                      <Setter Property="Visibility" Value="Visible" />
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </Border.Style>
              <StackPanel>
                <TextBlock Text="数据库与中间件发现审计" Style="{StaticResource SectionTitleStyle}" />
                <TextBlock Text="完整保留每次只读发现批次及候选状态，包括待确认、已确认、已排除和被新批次取代；这些记录不表示已连接实例或执行 SQL。"
                           Style="{StaticResource SecondaryTextStyle}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,12" />
                <ItemsControl ItemsSource="{Binding EvidenceCenter.HostSoftwareDiscoveries, Mode=OneWay}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border Background="{DynamicResource Brush.SurfaceSubtle}"
                              BorderBrush="{DynamicResource Brush.Border}"
                              BorderThickness="1"
                              CornerRadius="8"
                              Padding="14"
                              Margin="0,0,0,10">
                        <Grid>
                          <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.5*" />
                            <ColumnDefinition Width="1.2*" />
                            <ColumnDefinition Width="1.3*" />
                          </Grid.ColumnDefinitions>
                          <StackPanel Margin="0,0,16,0">
                            <StackPanel Orientation="Horizontal">
                              <TextBlock Text="{Binding Product, Mode=OneWay}" FontWeight="SemiBold" FontSize="16" />
                              <Border Background="{DynamicResource Brush.AccentSoft}" CornerRadius="10" Padding="8,2" Margin="10,0,0,0">
                                <TextBlock Text="{Binding CategoryText, Mode=OneWay}" Foreground="{DynamicResource Brush.Accent}" FontSize="11" />
                              </Border>
                            </StackPanel>
                            <TextBlock Text="{Binding DeviceName, Mode=OneWay}" Style="{StaticResource SecondaryTextStyle}" Margin="0,3,0,0" />
                            <TextBlock Text="{Binding InstanceName, Mode=OneWay, StringFormat=实例：{0}}" Margin="0,8,0,0" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding EvidenceSummary, Mode=OneWay, StringFormat=发现依据：{0}}"
                                       Style="{StaticResource SecondaryTextStyle}"
                                       TextWrapping="Wrap"
                                       Margin="0,4,0,0" />
                          </StackPanel>
                          <StackPanel Grid.Column="1" Margin="0,0,16,0">
                            <TextBlock Text="发现批次" Style="{StaticResource SecondaryTextStyle}" />
                            <TextBlock Text="{Binding BatchRevision, Mode=OneWay, StringFormat=修订：{0}}" Margin="0,4,0,0" />
                            <TextBlock Text="{Binding BatchRecordedAtText, Mode=OneWay}" Margin="0,4,0,0" />
                            <TextBlock Text="{Binding VersionText, Mode=OneWay, StringFormat=版本：{0}}" Margin="0,8,0,0" />
                            <TextBlock Text="{Binding InstallationTypeText, Mode=OneWay, StringFormat=方式：{0}}" Margin="0,4,0,0" />
                            <TextBlock Text="{Binding PortEvidenceText, Mode=OneWay, StringFormat=端口依据：{0}}" Margin="0,4,0,0" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding Confidence, Mode=OneWay, StringFormat=可信度：{0:P0}}" Margin="0,4,0,0" />
                          </StackPanel>
                          <StackPanel Grid.Column="2">
                            <TextBlock Text="人工决议" Style="{StaticResource SecondaryTextStyle}" />
                            <TextBlock Text="{Binding DecisionStatusText, Mode=OneWay}" FontWeight="SemiBold" Margin="0,4,0,0" />
                            <TextBlock Text="{Binding DecisionActorText, Mode=OneWay, StringFormat=处理人：{0}}" Margin="0,6,0,0" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding DecidedAtText, Mode=OneWay}" Margin="0,4,0,0" />
                            <TextBlock Text="{Binding DecisionSource, Mode=OneWay, TargetNullValue=尚无决议来源, StringFormat=来源：{0}}" Margin="0,4,0,0" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding DecisionReasonText, Mode=OneWay, StringFormat=理由：{0}}" Margin="0,4,0,0" TextWrapping="Wrap" />
                          </StackPanel>
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </Border>

            <Border automation:AutomationProperties.Name="数据库人工确认审计历史">
              <Border.Style>
                <Style TargetType="Border" BasedOn="{StaticResource CardStyle}">
                  <Setter Property="Visibility" Value="Collapsed" />
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding EvidenceCenter.HasDatabaseConfirmations}" Value="True">
                      <Setter Property="Visibility" Value="Visible" />
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </Border.Style>
              <StackPanel>
                <TextBlock Text="数据库人工确认审计" Style="{StaticResource SectionTitleStyle}" />
                <TextBlock Text="以下记录来自主机侧只读发现后的人工确认；它们不表示已经连接数据库或执行 SQL。"
                           Style="{StaticResource SecondaryTextStyle}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,12" />
                <ItemsControl ItemsSource="{Binding EvidenceCenter.DatabaseConfirmations}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border Background="{DynamicResource Brush.SurfaceSubtle}"
                              BorderBrush="{DynamicResource Brush.Border}"
                              BorderThickness="1"
                              CornerRadius="8"
                              Padding="14"
                              Margin="0,0,0,10">
                        <Grid>
                          <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.4*" />
                            <ColumnDefinition Width="1.2*" />
                            <ColumnDefinition Width="1.2*" />
                          </Grid.ColumnDefinitions>
                          <StackPanel Margin="0,0,16,0">
                            <TextBlock Text="{Binding Product}" FontWeight="SemiBold" FontSize="16" />
                            <TextBlock Text="{Binding DeviceName}" Style="{StaticResource SecondaryTextStyle}" Margin="0,3,0,0" />
                            <TextBlock Text="{Binding InstanceName, StringFormat=实例：{0}}" Margin="0,8,0,0" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding DetectionEvidence, StringFormat=发现依据：{0}}"
                                       Style="{StaticResource SecondaryTextStyle}"
                                       TextWrapping="Wrap"
                                       Margin="0,4,0,0" />
                          </StackPanel>
                          <StackPanel Grid.Column="1" Margin="0,0,16,0">
                            <TextBlock Text="识别信息" Style="{StaticResource SecondaryTextStyle}" />
                            <TextBlock Text="{Binding VersionText, StringFormat=版本：{0}}" Margin="0,4,0,0" />
                            <TextBlock Text="{Binding InstallationTypeText, StringFormat=方式：{0}}" Margin="0,4,0,0" />
                            <TextBlock Text="{Binding PortEvidenceText, StringFormat=端口依据：{0}}" Margin="0,4,0,0" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding Confidence, StringFormat=可信度：{0:P0}}" Margin="0,4,0,0" />
                          </StackPanel>
                          <StackPanel Grid.Column="2">
                            <TextBlock Text="确认记录" Style="{StaticResource SecondaryTextStyle}" />
                            <TextBlock Text="{Binding ConfirmedAtText}" FontWeight="SemiBold" Margin="0,4,0,0" />
                            <TextBlock Text="{Binding ConfirmationSource}" TextWrapping="Wrap" Margin="0,6,0,0" />
                          </StackPanel>
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </Border>

            <ItemsControl ItemsSource="{Binding EvidenceCenter.Items}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Style="{StaticResource CardStyle}">
                    <Grid>
                      <Grid.ColumnDefinitions><ColumnDefinition Width="2*" /><ColumnDefinition Width="1.2*" /><ColumnDefinition Width="1.2*" /></Grid.ColumnDefinitions>
                      <StackPanel>
                        <TextBlock Text="{Binding DeviceName}" FontWeight="SemiBold" FontSize="17" />
                        <TextBlock Text="{Binding CommandId}" FontFamily="Consolas" Style="{StaticResource SecondaryTextStyle}" />
                        <TextBlock Text="{Binding CommandText, StringFormat=命令：{0}}" TextWrapping="Wrap" Margin="0,7,16,0" />
                        <TextBlock Text="{Binding RawOutputPathText, StringFormat=原始输出：{0}}" Style="{StaticResource SecondaryTextStyle}" TextWrapping="Wrap" Margin="0,4,16,0" />
                      </StackPanel>
                      <StackPanel Grid.Column="1">
                        <TextBlock Text="执行结果" Style="{StaticResource SecondaryTextStyle}" />
                        <TextBlock Text="{Binding ExecutionStatusText}" FontWeight="SemiBold" Margin="0,3,0,10" />
                        <TextBlock Text="{Binding StartedAt, StringFormat=yyyy-MM-dd HH:mm:ss}" />
                      </StackPanel>
                      <StackPanel Grid.Column="2">
                        <TextBlock Text="证据完整性" Style="{StaticResource SecondaryTextStyle}" />
                        <TextBlock Text="{Binding ShaStatusText}" FontWeight="SemiBold" Margin="0,3,0,10" />
                        <TextBlock Text="{Binding ScreenshotCountText, StringFormat=截图：{0}}" />
                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                          <Button Content="定位原始输出"
                                  Command="{Binding DataContext.EvidenceCenter.OpenRawOutputCommand, RelativeSource={RelativeSource AncestorType={x:Type ItemsControl}}}"
                                  CommandParameter="{Binding}"
                                  Style="{StaticResource FluentSecondaryButtonStyle}"
                                  Margin="0,0,8,0"
                                  automation:AutomationProperties.Name="在资源管理器中安全定位当前命令原始输出" />
                          <Button Content="定位首张截图"
                                  Command="{Binding DataContext.EvidenceCenter.OpenFirstScreenshotCommand, RelativeSource={RelativeSource AncestorType={x:Type ItemsControl}}}"
                                  CommandParameter="{Binding}"
                                  Style="{StaticResource FluentSecondaryButtonStyle}"
                                  automation:AutomationProperties.Name="在资源管理器中安全定位当前命令首张证据截图" />
                        </StackPanel>
                      </StackPanel>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Border>
              <Border.Style>
                <Style TargetType="Border" BasedOn="{StaticResource CardStyle}">
                  <Setter Property="Visibility" Value="Collapsed" />
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding EvidenceCenter.State}" Value="NoProject"><Setter Property="Visibility" Value="Visible" /></DataTrigger>
                    <DataTrigger Binding="{Binding EvidenceCenter.State}" Value="Empty"><Setter Property="Visibility" Value="Visible" /></DataTrigger>
                  </Style.Triggers>
                </Style>
              </Border.Style>
              <TextBlock Text="请选择项目并完成一次只读采集；生成的人工确认审计、原始输出和截图会显示在这里。" TextWrapping="Wrap" />
            </Border>

            <Border BorderBrush="{DynamicResource Brush.Error}" BorderThickness="1" Background="{DynamicResource Brush.ErrorBackground}" CornerRadius="10" Padding="20">
              <Border.Style>
                <Style TargetType="Border">
                  <Setter Property="Visibility" Value="Collapsed" />
                  <Style.Triggers><DataTrigger Binding="{Binding EvidenceCenter.State}" Value="Failed"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers>
                </Style>
              </Border.Style>
              <StackPanel>
                <TextBlock Text="{Binding EvidenceCenter.WhatHappened}" Foreground="{DynamicResource Brush.Error}" FontWeight="SemiBold" />
                <TextBlock Text="{Binding EvidenceCenter.PossibleCause}" TextWrapping="Wrap" Margin="0,8,0,0" />
                <TextBlock Text="{Binding EvidenceCenter.HowToFix}" TextWrapping="Wrap" Margin="0,4,0,0" />
                <TextBlock Text="{Binding EvidenceCenter.TechnicalDetails}" Style="{StaticResource SecondaryTextStyle}" Margin="0,8,0,0" />
              </StackPanel>
            </Border>
          </StackPanel>
        </ScrollViewer>
      </TabItem>

      <TabItem Header="命令库">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
          <StackPanel Margin="28" MaxWidth="1100" HorizontalAlignment="Left">
            <Grid Margin="0,0,0,18">
              <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
              <StackPanel>
                <TextBlock Text="命令库审核与版本锁定" Style="{StaticResource PageTitleStyle}" />
                <TextBlock Text="导入内容先隔离为草稿；通过逐条只读复核后生成不可变版本，再由当前项目明确锁定。" Style="{StaticResource SecondaryTextStyle}" />
              </StackPanel>
              <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="导入 JSON 草稿" Command="{Binding CommandLibrary.ImportCommand}" Margin="0,0,8,0" automation:AutomationProperties.Name="导入待校验命令草稿" />
                <Button Content="刷新草稿" Command="{Binding CommandLibrary.RefreshCommand}" Style="{StaticResource FluentSecondaryButtonStyle}" />
              </StackPanel>
            </Grid>

            <Border Style="{StaticResource CardStyle}" Background="{DynamicResource Brush.WarningBackground}">
              <StackPanel>
                <TextBlock Text="安全隔离已启用" Style="{StaticResource SectionTitleStyle}" Foreground="{DynamicResource Brush.WarningText}" />
                <TextBlock Text="导入过程不会连接客户设备、不会建立 SSH 或数据库会话、不会执行任何命令。文件中自称“已验证”或“只读”的字段不会被信任。" TextWrapping="Wrap" />
                <TextBlock Text="草稿不能直接执行。发布时会忽略文件自称的可信状态，重新验证官方来源、版本范围、风险、分页方式和命令结构；单个 JSON 文件最大 1 MB。" Style="{StaticResource SecondaryTextStyle}" Margin="0,6,0,0" TextWrapping="Wrap" />
              </StackPanel>
            </Border>

            <Border Style="{StaticResource CardStyle}">
              <StackPanel>
                <TextBlock Text="{Binding CommandLibrary.StatusMessage, Mode=OneWay}" TextWrapping="Wrap" />
                <TextBlock Text="{Binding CommandLibrary.SelectedProjectText, Mode=OneWay}" Style="{StaticResource SecondaryTextStyle}" Margin="0,5,0,0" />
                <TextBlock Text="审核人（姓名或工号）" Margin="0,12,0,4" />
                <TextBox Text="{Binding CommandLibrary.ReviewerName, UpdateSourceTrigger=PropertyChanged}" MaxLength="120" automation:AutomationProperties.Name="命令包审核人" />
              </StackPanel>
            </Border>

            <ItemsControl ItemsSource="{Binding CommandLibrary.Drafts}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                      <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                        <StackPanel>
                          <TextBlock Text="{Binding SourceFileName}" Style="{StaticResource SectionTitleStyle}" />
                          <TextBlock Text="{Binding ImportedAtText, StringFormat=导入时间：{0}}" Style="{StaticResource SecondaryTextStyle}" />
                        </StackPanel>
                        <Border Grid.Column="1" Background="{DynamicResource Brush.ErrorBackground}" CornerRadius="12" Padding="10,4" VerticalAlignment="Top">
                          <TextBlock Text="{Binding ReviewStatusText}" Foreground="{DynamicResource Brush.Error}" FontWeight="SemiBold" />
                        </Border>
                      </Grid>
                      <Grid Margin="0,12,0,8">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="160" /><ColumnDefinition Width="160" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding CommandCount, StringFormat=命令数量：{0}}" />
                        <TextBlock Grid.Column="1" Text="{Binding BlockerCount, StringFormat=阻断项：{0}}" Foreground="{DynamicResource Brush.Error}" />
                        <TextBlock Grid.Column="2" Text="{Binding RawSha256, StringFormat=原始 SHA-256：{0}}" FontFamily="Consolas" TextTrimming="CharacterEllipsis" ToolTip="{Binding RawSha256}" />
                      </Grid>
                      <Button Content="安全审核并发布不可变版本"
                              Command="{Binding DataContext.CommandLibrary.PublishCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                              CommandParameter="{Binding}"
                              HorizontalAlignment="Left"
                              Margin="0,4,0,8"
                              automation:AutomationProperties.Name="安全审核并发布命令包" />
                      <ItemsControl ItemsSource="{Binding Findings}">
                        <ItemsControl.ItemTemplate>
                          <DataTemplate>
                            <Border Background="{DynamicResource Brush.SurfaceSubtle}" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,3">
                              <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Severity, StringFormat=[{0}]}" FontWeight="SemiBold" Margin="0,0,8,0" />
                                <TextBlock Text="{Binding Message}" TextWrapping="Wrap" />
                              </StackPanel>
                            </Border>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

            <TextBlock Text="已发布命令包" Style="{StaticResource SectionTitleStyle}" Margin="0,20,0,4" />
            <TextBlock Text="已发布版本不可修改或删除。切换和回滚都通过追加项目锁定记录完成，不覆盖历史。" Style="{StaticResource SecondaryTextStyle}" Margin="0,0,0,10" />
            <ItemsControl ItemsSource="{Binding CommandLibrary.PublishedPacks}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Style="{StaticResource CardStyle}">
                    <Grid>
                      <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                      <StackPanel>
                        <TextBlock Text="{Binding PackName}" Style="{StaticResource SectionTitleStyle}" />
                        <TextBlock Text="{Binding PackId, StringFormat=包标识：{0}}" Style="{StaticResource SecondaryTextStyle}" />
                        <TextBlock Text="{Binding Version, StringFormat=版本：{0}}" />
                        <TextBlock Text="{Binding ReviewedBy, StringFormat=审核人：{0}}" />
                        <TextBlock Text="{Binding PublishedAtText, StringFormat=发布时间：{0}}" Style="{StaticResource SecondaryTextStyle}" />
                        <TextBlock Text="{Binding OfficialSource, StringFormat=官方来源：{0}}" TextTrimming="CharacterEllipsis" ToolTip="{Binding OfficialSource}" />
                        <TextBlock Text="{Binding RawSha256, StringFormat=SHA-256：{0}}" FontFamily="Consolas" TextTrimming="CharacterEllipsis" ToolTip="{Binding RawSha256}" />
                        <TextBlock Text="{Binding ProjectLockStatusText}" Foreground="{DynamicResource Brush.Accent}" Margin="0,7,0,0" />
                      </StackPanel>
                      <Button Grid.Column="1"
                              Content="{Binding ProjectLockActionText}"
                              Command="{Binding DataContext.CommandLibrary.LockCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                              CommandParameter="{Binding}"
                              VerticalAlignment="Top"
                              Margin="16,0,0,0"
                              automation:AutomationProperties.Name="锁定命令包版本到当前项目" />
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </ScrollViewer>
      </TabItem>

      <TabItem Header="组件中心">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
          <StackPanel Margin="28" MaxWidth="860" HorizontalAlignment="Left">
            <TextBlock Text="组件中心" Style="{StaticResource PageTitleStyle}" />
            <Border Style="{StaticResource CardStyle}">
              <StackPanel>
                <TextBlock Text="{Binding ComponentCenter.ComponentName}" Style="{StaticResource SectionTitleStyle}" />
                <TextBlock Text="{Binding ComponentCenter.StatusText}" FontWeight="SemiBold">
                  <TextBlock.Style>
                    <Style TargetType="TextBlock">
                      <Setter Property="Foreground" Value="{DynamicResource Brush.WarningText}" />
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding ComponentCenter.ComponentState}" Value="Available">
                          <Setter Property="Foreground" Value="{DynamicResource Brush.Success}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding ComponentCenter.ComponentState}" Value="Invalid">
                          <Setter Property="Foreground" Value="{DynamicResource Brush.Error}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding ComponentCenter.ComponentState}" Value="CheckFailed">
                          <Setter Property="Foreground" Value="{DynamicResource Brush.Error}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding ComponentCenter.State}" Value="Failed">
                          <Setter Property="Foreground" Value="{DynamicResource Brush.Error}" />
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </TextBlock.Style>
                </TextBlock>

                <Grid Margin="0,14,0,0">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                  </Grid.RowDefinitions>
                  <TextBlock Grid.Row="0" Text="来源" Foreground="{DynamicResource Brush.TextSecondary}" />
                  <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding ComponentCenter.Source}" TextWrapping="Wrap" />
                  <TextBlock Grid.Row="1" Text="体积" Foreground="{DynamicResource Brush.TextSecondary}" />
                  <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding ComponentCenter.Size}" />
                  <TextBlock Grid.Row="2" Text="联网" Foreground="{DynamicResource Brush.TextSecondary}" />
                  <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding ComponentCenter.NetworkRequirement}" TextWrapping="Wrap" />
                  <TextBlock Grid.Row="3" Text="管理员权限" Foreground="{DynamicResource Brush.TextSecondary}" />
                  <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding ComponentCenter.AdministratorRequirement}" />
                  <TextBlock Grid.Row="4" Text="重启" Foreground="{DynamicResource Brush.TextSecondary}" />
                  <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding ComponentCenter.RestartRequirement}" />
                </Grid>

                <TextBlock Text="影响" FontWeight="SemiBold" Margin="0,16,0,2" />
                <TextBlock Text="{Binding ComponentCenter.UserImpact}" TextWrapping="Wrap" />
                <TextBlock Text="处理办法" FontWeight="SemiBold" Margin="0,12,0,2" />
                <TextBlock Text="{Binding ComponentCenter.OfflineInstructions}" TextWrapping="Wrap" />
                <TextBlock Text="{Binding ComponentCenter.AutomaticActionNotice}"
                           Foreground="{DynamicResource Brush.WarningText}"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap"
                           Margin="0,12,0,0" />
                <Border Background="{DynamicResource Brush.SurfaceSubtle}"
                        BorderBrush="{DynamicResource Brush.Border}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="12"
                        Margin="0,14,0,0">
                  <StackPanel>
                    <TextBlock Text="离线安装或修复" FontWeight="SemiBold" />
                    <TextBlock Text="选择文件后先校验固定 SHA-256；软件显示结果并再次询问，确认前不会复制或替换文件。"
                               Style="{StaticResource SecondaryTextStyle}"
                               TextWrapping="Wrap"
                               Margin="0,4,0,8" />
                    <TextBlock Text="{Binding ComponentCenter.PreparedInstallSummary, Mode=OneWay}"
                               FontFamily="Consolas"
                               TextWrapping="Wrap" />
                    <TextBlock Text="{Binding ComponentCenter.InstallStatusMessage, Mode=OneWay}"
                               Style="{StaticResource SecondaryTextStyle}"
                               TextWrapping="Wrap"
                               Margin="0,6,0,0" />
                  </StackPanel>
                </Border>
                <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                  <Button Content="选择离线安装包"
                          Style="{StaticResource FluentSecondaryButtonStyle}"
                          Click="SelectPlinkInstallPackage_Click"
                          automation:AutomationProperties.Name="选择并校验 Plink 离线安装包" />
                  <Button Content="重新检测"
                          Command="{Binding ComponentCenter.RefreshCommand}"
                          automation:AutomationProperties.Name="重新检测 Plink 连接组件" />
                </StackPanel>
              </StackPanel>
            </Border>
          </StackPanel>
        </ScrollViewer>
      </TabItem>

      <TabItem IsEnabled="False" Focusable="False">
        <TabItem.Header><StackPanel><TextBlock Text="设置" /><TextBlock Text="后续版本" FontSize="11" Foreground="{DynamicResource Brush.DisabledText}" /></StackPanel></TabItem.Header>
      </TabItem>
    </TabControl>
  </Grid>
  </Grid>
</Window>
