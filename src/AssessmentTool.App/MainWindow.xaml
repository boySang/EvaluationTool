<Window x:Class="AssessmentTool.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:automation="clr-namespace:System.Windows.Automation;assembly=PresentationCore"
        Title="等级保护测评辅助工具"
        Width="1440"
        Height="900"
        MinWidth="1100"
        MinHeight="720"
        WindowStartupLocation="CenterScreen"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
  <Grid Background="{DynamicResource Brush.Window}">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="216" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>

    <Border Grid.Column="0"
            Background="{DynamicResource Brush.Navigation}"
            BorderBrush="{DynamicResource Brush.Border}"
            BorderThickness="0,0,1,0">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="72" />
          <RowDefinition Height="*" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="16,16,10,12" VerticalAlignment="Center">
          <Border Width="38" Height="38" CornerRadius="8" Background="{DynamicResource Brush.Accent}" Margin="0,0,10,0">
            <TextBlock Text="安" Foreground="White" FontWeight="Bold" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Border>
          <StackPanel VerticalAlignment="Center">
            <TextBlock Text="等级保护测评" FontWeight="SemiBold" FontSize="15" />
            <TextBlock Text="辅助工具" Foreground="{DynamicResource Brush.TextSecondary}" FontSize="12" />
          </StackPanel>
        </StackPanel>

        <ListBox x:Name="ShellNavigation"
                 Grid.Row="1"
                 SelectedIndex="0"
                 Style="{StaticResource ShellNavigationStyle}"
                 ItemContainerStyle="{StaticResource ShellNavigationItemStyle}"
                 automation:AutomationProperties.Name="主导航">
          <ListBoxItem>
            <StackPanel Orientation="Horizontal"><TextBlock Text="⌂" FontSize="18" Width="30" /><TextBlock Text="首页" VerticalAlignment="Center" /></StackPanel>
          </ListBoxItem>
          <ListBoxItem>
            <StackPanel Orientation="Horizontal"><TextBlock Text="▣" FontSize="16" Width="30" /><TextBlock Text="项目" VerticalAlignment="Center" /></StackPanel>
          </ListBoxItem>
          <ListBoxItem>
            <StackPanel Orientation="Horizontal"><TextBlock Text="▯" FontSize="18" Width="30" /><TextBlock Text="设备" VerticalAlignment="Center" /></StackPanel>
          </ListBoxItem>
          <ListBoxItem>
            <StackPanel Orientation="Horizontal"><TextBlock Text="☷" FontSize="18" Width="30" /><TextBlock Text="采集任务" VerticalAlignment="Center" /></StackPanel>
          </ListBoxItem>
          <ListBoxItem>
            <StackPanel Orientation="Horizontal"><TextBlock Text="▧" FontSize="17" Width="30" /><TextBlock Text="证据中心" VerticalAlignment="Center" /></StackPanel>
          </ListBoxItem>
          <ListBoxItem IsEnabled="False">
            <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="30" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><TextBlock Text="&gt;_" FontSize="13" /><TextBlock Grid.Column="1" Text="命令库" /><TextBlock Grid.Column="2" Text="后续" FontSize="10" Foreground="{DynamicResource Brush.DisabledText}" /></Grid>
          </ListBoxItem>
          <ListBoxItem>
            <StackPanel Orientation="Horizontal"><TextBlock Text="▦" FontSize="17" Width="30" /><TextBlock Text="组件中心" VerticalAlignment="Center" /></StackPanel>
          </ListBoxItem>
          <ListBoxItem IsEnabled="False">
            <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="30" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><TextBlock Text="⚙" FontSize="16" /><TextBlock Grid.Column="1" Text="设置" /><TextBlock Grid.Column="2" Text="后续" FontSize="10" Foreground="{DynamicResource Brush.DisabledText}" /></Grid>
          </ListBoxItem>
        </ListBox>

        <StackPanel Grid.Row="2" Margin="16,10,16,18">
          <Border Style="{StaticResource ReadOnlyPillStyle}" HorizontalAlignment="Left">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="●" Foreground="{DynamicResource Brush.Success}" FontSize="10" Margin="0,0,7,0" VerticalAlignment="Center" />
              <TextBlock Text="只读保护已开启" FontSize="12" Foreground="{DynamicResource Brush.Success}" />
            </StackPanel>
          </Border>
          <TextBlock Text="本地离线运行 · 不自动上传" Style="{StaticResource SecondaryTextStyle}" FontSize="11" Margin="0,8,0,0" />
        </StackPanel>
      </Grid>
    </Border>

    <Grid Grid.Column="1">
      <Grid.RowDefinitions>
        <RowDefinition Height="58" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>

      <Border Grid.Row="0" Background="{DynamicResource Brush.Surface}" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="0,0,0,1" Padding="22,0">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>
          <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <TextBlock Text="▣" Foreground="{DynamicResource Brush.TextSecondary}" Margin="0,0,8,0" />
            <TextBlock Text="项目：" Foreground="{DynamicResource Brush.TextSecondary}" />
            <TextBlock Text="{Binding CurrentProjectName}" FontWeight="SemiBold" MaxWidth="360" TextTrimming="CharacterEllipsis" ToolTip="{Binding CurrentProjectName}" />
          </StackPanel>
          <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
            <Border x:Name="ReadOnlyStatusBadge" Style="{StaticResource ReadOnlyPillStyle}" Margin="0,0,12,0">
              <StackPanel Orientation="Horizontal">
                <TextBlock Text="✓" Foreground="{DynamicResource Brush.Success}" Margin="0,0,6,0" />
                <TextBlock Text="{Binding ReadOnlyProtectionStatus}" Foreground="{DynamicResource Brush.Success}" FontSize="12" />
              </StackPanel>
            </Border>
            <Button Content="◐"
                    Style="{StaticResource FluentIconButtonStyle}"
                    Command="{Binding ToggleThemeCommand}"
                    automation:AutomationProperties.Name="切换浅色或深色主题" />
          </StackPanel>
        </Grid>
      </Border>

      <TabControl Grid.Row="1"
                  Style="{StaticResource ContentOnlyTabControlStyle}"
                  SelectedIndex="{Binding SelectedIndex, ElementName=ShellNavigation, Mode=OneWay}"
                  automation:AutomationProperties.Name="页面内容">
      <TabItem Header="首页">
        <Grid Margin="24">
          <Grid.RowDefinitions>
            <RowDefinition Height="146" />
            <RowDefinition Height="16" />
            <RowDefinition Height="104" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>

          <Border Grid.Row="0" Style="{StaticResource FluentCardStyle}" Background="{DynamicResource Brush.SurfaceSubtle}">
            <Grid>
              <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="330" /></Grid.ColumnDefinitions>
              <StackPanel VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal">
                  <TextBlock Text="项目测评工作台" Style="{StaticResource PageTitleStyle}" Margin="0,0,12,6" />
                  <Border Style="{StaticResource ReadOnlyPillStyle}" VerticalAlignment="Top">
                    <TextBlock Text="只读模式" Foreground="{DynamicResource Brush.Success}" FontSize="11" />
                  </Border>
                </StackPanel>
                <TextBlock Text="管理当前项目设备、只读采集任务和测评证据。所有自动命令在执行前都要通过安全策略校验。" Style="{StaticResource SecondaryTextStyle}" />
                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                  <Button Content="＋  添加设备" Click="NavigateToDevices_Click" automation:AutomationProperties.Name="转到设备页面添加设备" />
                  <Button Content="创建采集任务" Style="{StaticResource FluentSecondaryButtonStyle}" Click="NavigateToCollection_Click" automation:AutomationProperties.Name="转到采集任务页面" />
                </StackPanel>
              </StackPanel>
              <Border Grid.Column="1" Background="{DynamicResource Brush.AccentSoft}" CornerRadius="8" Padding="18">
                <StackPanel VerticalAlignment="Center">
                  <TextBlock Text="本机安全工作区" FontWeight="SemiBold" FontSize="16" />
                  <TextBlock Text="✓ 凭据由 Windows DPAPI 加密" Style="{StaticResource SecondaryTextStyle}" Margin="0,8,0,0" />
                  <TextBlock Text="✓ 客户资料默认不上传" Style="{StaticResource SecondaryTextStyle}" Margin="0,4,0,0" />
                  <TextBlock Text="✓ 首次 SSH 连接必须确认指纹" Style="{StaticResource SecondaryTextStyle}" Margin="0,4,0,0" />
                </StackPanel>
              </Border>
            </Grid>
          </Border>

          <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" /><ColumnDefinition Width="12" />
              <ColumnDefinition Width="*" /><ColumnDefinition Width="12" />
              <ColumnDefinition Width="*" /><ColumnDefinition Width="12" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Style="{StaticResource DashboardStatCardStyle}">
              <StackPanel><TextBlock Text="项目设备" Style="{StaticResource SecondaryTextStyle}" /><TextBlock x:Name="DashboardDeviceCount" Text="{Binding ProjectDeviceCount, Mode=OneWay}" Style="{StaticResource DashboardMetricStyle}" /><TextBlock Text="当前项目已保存的设备" Style="{StaticResource SecondaryTextStyle}" FontSize="11" /></StackPanel>
            </Border>
            <Border Grid.Column="2" Style="{StaticResource DashboardStatCardStyle}">
              <StackPanel><TextBlock Text="连接测试通过" Style="{StaticResource SecondaryTextStyle}" /><TextBlock Text="{Binding SuccessfulConnectionTestCount, Mode=OneWay}" Style="{StaticResource DashboardMetricStyle}" /><TextBlock Text="完成指纹确认和登录测试" Style="{StaticResource SecondaryTextStyle}" FontSize="11" /></StackPanel>
            </Border>
            <Border Grid.Column="4" Style="{StaticResource DashboardStatCardStyle}">
              <StackPanel><TextBlock Text="待连接测试" Style="{StaticResource SecondaryTextStyle}" /><TextBlock Text="{Binding PendingConnectionTestCount, Mode=OneWay}" Style="{StaticResource DashboardMetricStyle}" /><TextBlock Text="尚未完成安全连接闭环" Style="{StaticResource SecondaryTextStyle}" FontSize="11" /></StackPanel>
            </Border>
            <Border Grid.Column="6" Style="{StaticResource DashboardStatCardStyle}">
              <StackPanel><TextBlock Text="采集失败" Style="{StaticResource SecondaryTextStyle}" /><TextBlock Text="{Binding CollectionFailureCount, Mode=OneWay}" Style="{StaticResource DashboardMetricStyle}" Foreground="{DynamicResource Brush.Error}" /><TextBlock Text="当前会话需要处理的失败" Style="{StaticResource SecondaryTextStyle}" FontSize="11" /></StackPanel>
            </Border>
          </Grid>

          <Grid Grid.Row="4">
            <Grid.ColumnDefinitions><ColumnDefinition Width="2*" /><ColumnDefinition Width="16" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
            <Border Grid.Column="0" Style="{StaticResource FluentCardStyle}" Padding="0">
              <Grid>
                <Grid.RowDefinitions><RowDefinition Height="54" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                <Grid Grid.Row="0" Margin="16,0">
                  <TextBlock Text="最近设备" Style="{StaticResource SectionTitleStyle}" Margin="0" VerticalAlignment="Center" />
                  <Button Content="进入设备列表" Style="{StaticResource FluentSecondaryButtonStyle}" HorizontalAlignment="Right" VerticalAlignment="Center" Click="NavigateToDevices_Click" />
                </Grid>
                <ListBox Grid.Row="1" ItemsSource="{Binding Workspace.Devices}" SelectedItem="{Binding Workspace.SelectedDevice, Mode=TwoWay}" BorderThickness="0" ItemContainerStyle="{StaticResource DashboardListItemStyle}">
                  <ListBox.ItemTemplate>
                    <DataTemplate>
                      <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="2*" /><ColumnDefinition Width="1.5*" /><ColumnDefinition Width="100" /></Grid.ColumnDefinitions>
                        <StackPanel><TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" /><TextBlock Text="SSH 设备" Style="{StaticResource SecondaryTextStyle}" FontSize="11" /></StackPanel>
                        <TextBlock Grid.Column="1" Text="{Binding Host}" VerticalAlignment="Center" FontFamily="Consolas" />
                        <Border Grid.Column="2" Background="{DynamicResource Brush.WarningBackground}" CornerRadius="10" Padding="8,3" HorizontalAlignment="Left" VerticalAlignment="Center"><TextBlock Text="待连接测试" Foreground="{DynamicResource Brush.WarningText}" FontSize="11" /></Border>
                      </Grid>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
                <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                  <StackPanel.Style>
                    <Style TargetType="StackPanel">
                      <Setter Property="Visibility" Value="Collapsed" />
                      <Style.Triggers><DataTrigger Binding="{Binding ProjectDeviceCount}" Value="0"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers>
                    </Style>
                  </StackPanel.Style>
                  <TextBlock Text="尚未添加设备" FontWeight="SemiBold" HorizontalAlignment="Center" />
                  <TextBlock Text="先选择项目，再添加需要测评的设备。" Style="{StaticResource SecondaryTextStyle}" Margin="0,6,0,8" />
                  <Button Content="添加第一台设备" Click="NavigateToDevices_Click" />
                </StackPanel>
              </Grid>
            </Border>

            <StackPanel Grid.Column="2">
              <Border Style="{StaticResource FluentCardStyle}" Margin="0,0,0,12">
                <StackPanel>
                  <TextBlock Text="待处理事项" Style="{StaticResource SectionTitleStyle}" />
                  <Grid Margin="0,4"><TextBlock Text="设备待连接测试" /><Border Background="{DynamicResource Brush.WarningBackground}" CornerRadius="10" Padding="8,2" HorizontalAlignment="Right"><TextBlock Text="{Binding PendingConnectionTestCount, Mode=OneWay}" Foreground="{DynamicResource Brush.WarningText}" /></Border></Grid>
                  <Grid Margin="0,8,0,4"><TextBlock Text="采集失败" /><Border Background="{DynamicResource Brush.ErrorBackground}" CornerRadius="10" Padding="8,2" HorizontalAlignment="Right"><TextBlock Text="{Binding CollectionFailureCount, Mode=OneWay}" Foreground="{DynamicResource Brush.Error}" /></Border></Grid>
                </StackPanel>
              </Border>
              <Border Style="{StaticResource FluentCardStyle}">
                <StackPanel>
                  <TextBlock Text="运行环境" Style="{StaticResource SectionTitleStyle}" />
                  <TextBlock Text="SSH 连接组件" FontWeight="SemiBold" />
                  <TextBlock Text="{Binding ComponentCenter.StatusText, Mode=OneWay}" Style="{StaticResource SecondaryTextStyle}" Margin="0,5,0,10" />
                  <Button Content="查看组件中心" Style="{StaticResource FluentSecondaryButtonStyle}" Click="NavigateToComponents_Click" HorizontalAlignment="Left" />
                </StackPanel>
              </Border>
            </StackPanel>
          </Grid>
        </Grid>
      </TabItem>

      <TabItem Header="项目">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
          <StackPanel Margin="28" MaxWidth="760" HorizontalAlignment="Left">
            <TextBlock Text="客户与项目" Style="{StaticResource PageTitleStyle}" />
            <TextBlock Text="项目资料将用于证据目录和执行记录。不会自动上传客户数据。" Style="{StaticResource SecondaryTextStyle}" Margin="0,0,0,20" />
            <Border Style="{StaticResource CardStyle}">
              <StackPanel>
                <TextBlock Text="新建项目" Style="{StaticResource SectionTitleStyle}" />
                <TextBlock Text="客户名称" />
                <TextBox Text="{Binding Workspace.CustomerName, UpdateSourceTrigger=PropertyChanged}" automation:AutomationProperties.Name="客户名称" />
                <TextBlock Text="项目名称" />
                <TextBox Text="{Binding Workspace.ProjectName, UpdateSourceTrigger=PropertyChanged}" automation:AutomationProperties.Name="项目名称" />
                <TextBlock Text="证据保存目录" />
                <TextBox Text="{Binding Workspace.EvidenceRoot, UpdateSourceTrigger=PropertyChanged}" automation:AutomationProperties.Name="证据保存目录" />
                <Button Content="创建并保存项目" Click="CreateProject_Click" automation:AutomationProperties.Name="创建并保存项目" />
                <TextBlock Text="项目资料保存在当前 Windows 用户的本地 SQLite 数据库中，不会自动上传。" Style="{StaticResource SecondaryTextStyle}" />
              </StackPanel>
            </Border>
            <Border Style="{StaticResource CardStyle}">
              <StackPanel>
                <TextBlock Text="已保存项目" Style="{StaticResource SectionTitleStyle}" />
                <ListBox ItemsSource="{Binding Workspace.Projects}"
                         SelectedItem="{Binding Workspace.SelectedProject, Mode=OneWay}"
                         SelectionChanged="ProjectSelection_Changed"
                         MinHeight="120"
                         automation:AutomationProperties.Name="已保存项目列表">
                  <ListBox.ItemTemplate>
                    <DataTemplate>
                      <StackPanel Margin="4">
                        <TextBlock Text="{Binding ProjectName}" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding CustomerName}" Style="{StaticResource SecondaryTextStyle}" />
                      </StackPanel>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
              </StackPanel>
            </Border>
            <Border BorderBrush="{DynamicResource Brush.Error}" BorderThickness="1" Background="{DynamicResource Brush.ErrorBackground}" CornerRadius="10" Padding="20">
              <Border.Style>
                <Style TargetType="Border">
                  <Setter Property="Visibility" Value="Collapsed" />
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding Workspace.State}" Value="Failed"><Setter Property="Visibility" Value="Visible" /></DataTrigger>
                  </Style.Triggers>
                </Style>
              </Border.Style>
              <StackPanel automation:AutomationProperties.LiveSetting="Assertive">
                <TextBlock Text="{Binding Workspace.WhatHappened}" Foreground="{DynamicResource Brush.Error}" FontWeight="SemiBold" />
                <TextBlock Text="{Binding Workspace.PossibleCause}" TextWrapping="Wrap" Margin="0,8,0,0" />
                <TextBlock Text="{Binding Workspace.HowToFix}" TextWrapping="Wrap" Margin="0,8,0,0" />
                <Expander Header="技术详情" Margin="0,8,0,0">
                  <TextBox Text="{Binding Workspace.TechnicalDetails, Mode=OneWay}" IsReadOnly="True" />
                </Expander>
              </StackPanel>
            </Border>
          </StackPanel>
        </ScrollViewer>
      </TabItem>

      <TabItem Header="设备">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
          <Grid Margin="28">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" MinWidth="360" />
              <ColumnDefinition Width="16" />
              <ColumnDefinition Width="*" MinWidth="360" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
              <TextBlock Text="设备与连接" Style="{StaticResource PageTitleStyle}" />
              <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                  <TextBlock Text="基础信息" Style="{StaticResource SectionTitleStyle}" />
                  <TextBlock Text="设备名称" />
                  <TextBox Text="{Binding Workspace.DeviceDisplayName, UpdateSourceTrigger=PropertyChanged}" automation:AutomationProperties.Name="设备名称" />
                  <TextBlock Text="主机地址" />
                  <TextBox Text="{Binding Workspace.DeviceHost, UpdateSourceTrigger=PropertyChanged}" automation:AutomationProperties.Name="主机地址" />
                  <TextBlock Text="SSH 端口" />
                  <TextBox Text="{Binding Workspace.DevicePortText, UpdateSourceTrigger=PropertyChanged}" automation:AutomationProperties.Name="SSH 端口" />
                  <TextBlock Text="连接密码" />
                  <PasswordBox x:Name="DevicePasswordBox" automation:AutomationProperties.Name="连接密码" />
                  <Button Content="加密保存设备" Click="SaveDevice_Click" automation:AutomationProperties.Name="使用 DPAPI 加密保存设备" />
                  <TextBlock Text="密码由当前 Windows 用户的 DPAPI 加密，SQLite 只保存不可逆的凭据引用。" Style="{StaticResource SecondaryTextStyle}" />
                </StackPanel>
              </Border>
              <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                  <TextBlock Text="当前项目设备" Style="{StaticResource SectionTitleStyle}" />
                  <ListBox ItemsSource="{Binding Workspace.Devices}"
                           SelectedItem="{Binding Workspace.SelectedDevice, Mode=TwoWay}"
                           MinHeight="120"
                           automation:AutomationProperties.Name="当前项目设备列表">
                    <ListBox.ItemTemplate>
                      <DataTemplate>
                        <StackPanel Margin="4">
                          <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" />
                          <TextBlock Text="{Binding Host, StringFormat={}{0}}" Style="{StaticResource SecondaryTextStyle}" />
                        </StackPanel>
                      </DataTemplate>
                    </ListBox.ItemTemplate>
                  </ListBox>
                </StackPanel>
              </Border>
              <Border Style="{StaticResource CardStyle}" Background="{DynamicResource Brush.WarningBackground}">
                <TextBlock Text="首次连接必须核对主机指纹；指纹变化会阻止自动连接。" Foreground="{DynamicResource Brush.WarningText}" TextWrapping="Wrap" />
              </Border>
            </StackPanel>

            <StackPanel Grid.Column="2">
              <TextBlock Text="识别与人工确认" Style="{StaticResource PageTitleStyle}" />
              <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                  <TextBlock Text="设备识别候选" Style="{StaticResource SectionTitleStyle}" />
                  <TextBlock Text="低可信、冲突或未知结果不会自动执行完整命令包。" Style="{StaticResource SecondaryTextStyle}" Margin="0,0,0,10" />
                  <ItemsControl ItemsSource="{Binding Collection.DetectionCandidates}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <Border Style="{StaticResource CardStyle}">
                          <StackPanel>
                            <TextBlock Text="{Binding ProductFamily, TargetNullValue=未知产品}" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding Version, StringFormat=版本：{0}, TargetNullValue=版本未知}" />
                            <TextBlock Text="{Binding Confidence, StringFormat=可信度：{0:P0}}" />
                            <TextBlock Text="{Binding Evidence}" Style="{StaticResource SecondaryTextStyle}" />
                            <Button Content="确认此识别结果"
                                    Command="{Binding DataContext.Collection.ConfirmDetectionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding}" />
                          </StackPanel>
                        </Border>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </StackPanel>
              </Border>

              <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                  <TextBlock Text="发现的数据库实例" Style="{StaticResource SectionTitleStyle}" />
                  <TextBlock Text="确认仅保存发现结果；Phase 1 不建立数据库直连，也不执行 SQL。" Style="{StaticResource SecondaryTextStyle}" Margin="0,0,0,10" />
                  <ItemsControl ItemsSource="{Binding Collection.DatabaseCandidates}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <Border Style="{StaticResource CardStyle}">
                          <StackPanel>
                            <TextBlock Text="{Binding Product}" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding Version, StringFormat=版本：{0}, TargetNullValue=版本未知，需要人工确认}" />
                            <TextBlock Text="{Binding InstallationType, StringFormat=安装方式：{0}}" />
                            <TextBlock Text="{Binding InstanceName, StringFormat=实例：{0}}" />
                            <TextBlock Text="{Binding PortEvidence, StringFormat=端口依据：{0}, TargetNullValue=未发现端口依据}" />
                            <TextBlock Text="{Binding Confidence, StringFormat=可信度：{0:P0}}" />
                            <Expander Header="查看识别依据">
                              <TextBox Text="{Binding Evidence, Mode=OneWay}" IsReadOnly="True" TextWrapping="Wrap" />
                            </Expander>
                            <Button Content="确认此数据库实例"
                                    Command="{Binding DataContext.Collection.ConfirmDatabaseCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding}" />
                          </StackPanel>
                        </Border>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </StackPanel>
              </Border>
            </StackPanel>
          </Grid>
        </ScrollViewer>
      </TabItem>

      <TabItem Header="采集任务">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
          <StackPanel Margin="28" MaxWidth="900" HorizontalAlignment="Left">
            <TextBlock Text="只读采集任务" Style="{StaticResource PageTitleStyle}" />
            <TextBlock Text="自动采集区不提供自由命令输入，只执行已验证命令包。" Style="{StaticResource SecondaryTextStyle}" Margin="0,0,0,20" />
            <Border Style="{StaticResource CardStyle}" Background="{DynamicResource Brush.WarningBackground}">
              <TextBlock Text="当前版本尚未接通真实设备连接；本页仅用于验证只读采集状态、确认和停止流程。" Foreground="{DynamicResource Brush.WarningText}" TextWrapping="Wrap" />
            </Border>
            <Border Style="{StaticResource CardStyle}">
              <StackPanel>
                <TextBlock Text="{Binding Collection.State, StringFormat=当前状态：{0}}" Style="{StaticResource SectionTitleStyle}" />
                <TextBlock Text="{Binding Collection.ProgressMessage, TargetNullValue=等待开始}" TextWrapping="Wrap" />
                <TextBlock Text="{Binding Collection.CurrentCommand, StringFormat=当前命令编号：{0}, TargetNullValue=尚未执行命令}" Style="{StaticResource SecondaryTextStyle}" Margin="0,6" />
                <ProgressBar Height="8"
                             Minimum="0"
                             Maximum="{Binding Collection.TotalCommandCount, Mode=OneWay}"
                             Value="{Binding Collection.CompletedCommandCount, Mode=OneWay}"
                             Margin="0,10" />
                <TextBlock Text="{Binding Collection.CompletedCommandCount, StringFormat=已完成 {0} 条}" />
                <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                  <Button Content="开始只读采集（尚未接通）" Command="{Binding Collection.StartCommand}" automation:AutomationProperties.Name="开始只读采集，当前尚未接通" />
                  <Button Content="安全停止" Command="{Binding Collection.StopCommand}" automation:AutomationProperties.Name="安全停止采集" />
                </StackPanel>
              </StackPanel>
            </Border>

            <Border BorderBrush="{DynamicResource Brush.Error}" BorderThickness="1" Background="{DynamicResource Brush.ErrorBackground}" CornerRadius="10" Padding="20">
              <Border.Style>
                <Style TargetType="Border">
                  <Setter Property="Visibility" Value="Collapsed" />
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding Collection.Error}" Value="{x:Null}"><Setter Property="Visibility" Value="Collapsed" /></DataTrigger>
                    <DataTrigger Binding="{Binding Collection.State}" Value="Failed"><Setter Property="Visibility" Value="Visible" /></DataTrigger>
                  </Style.Triggers>
                </Style>
              </Border.Style>
              <StackPanel automation:AutomationProperties.LiveSetting="Assertive">
                <TextBlock Text="{Binding Collection.Error.Summary}" Foreground="{DynamicResource Brush.Error}" FontWeight="SemiBold" FontSize="17" />
                <TextBlock Text="可能原因" FontWeight="SemiBold" Margin="0,10,0,2" />
                <TextBlock Text="{Binding Collection.Error.PossibleCause}" TextWrapping="Wrap" />
                <TextBlock Text="怎么处理" FontWeight="SemiBold" Margin="0,10,0,2" />
                <TextBlock Text="{Binding Collection.Error.RecommendedAction}" TextWrapping="Wrap" />
                <Expander Header="技术详情" Margin="0,10,0,0">
                  <TextBox Text="{Binding Collection.Error.TechnicalDetails, Mode=OneWay}" IsReadOnly="True" TextWrapping="Wrap" />
                </Expander>
              </StackPanel>
            </Border>
          </StackPanel>
        </ScrollViewer>
      </TabItem>

      <TabItem Header="证据">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
          <StackPanel Margin="28" MaxWidth="860" HorizontalAlignment="Left">
            <TextBlock Text="证据" Style="{StaticResource PageTitleStyle}" />
            <Border Style="{StaticResource CardStyle}">
              <StackPanel>
                <TextBlock Text="原始输出、截图和完整性校验" Style="{StaticResource SectionTitleStyle}" />
                <TextBlock Text="完成采集后，这里会显示证据目录、原始输出、连续截图和 SHA-256 校验状态。" Style="{StaticResource SecondaryTextStyle}" />
              </StackPanel>
            </Border>
          </StackPanel>
        </ScrollViewer>
      </TabItem>

      <TabItem IsEnabled="False" Focusable="False">
        <TabItem.Header><StackPanel><TextBlock Text="命令库" /><TextBlock Text="后续版本" FontSize="11" Foreground="{DynamicResource Brush.DisabledText}" /></StackPanel></TabItem.Header>
      </TabItem>

      <TabItem Header="组件中心">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
          <StackPanel Margin="28" MaxWidth="860" HorizontalAlignment="Left">
            <TextBlock Text="组件中心" Style="{StaticResource PageTitleStyle}" />
            <Border Style="{StaticResource CardStyle}">
              <StackPanel>
                <TextBlock Text="{Binding ComponentCenter.ComponentName}" Style="{StaticResource SectionTitleStyle}" />
                <TextBlock Text="{Binding ComponentCenter.StatusText}" FontWeight="SemiBold">
                  <TextBlock.Style>
                    <Style TargetType="TextBlock">
                      <Setter Property="Foreground" Value="{DynamicResource Brush.WarningText}" />
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding ComponentCenter.ComponentState}" Value="Available">
                          <Setter Property="Foreground" Value="{DynamicResource Brush.Success}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding ComponentCenter.ComponentState}" Value="Invalid">
                          <Setter Property="Foreground" Value="{DynamicResource Brush.Error}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding ComponentCenter.ComponentState}" Value="CheckFailed">
                          <Setter Property="Foreground" Value="{DynamicResource Brush.Error}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding ComponentCenter.State}" Value="Failed">
                          <Setter Property="Foreground" Value="{DynamicResource Brush.Error}" />
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </TextBlock.Style>
                </TextBlock>

                <Grid Margin="0,14,0,0">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150" />
                    <ColumnDefinition Width="*" />
                  </Grid.ColumnDefinitions>
                  <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                  </Grid.RowDefinitions>
                  <TextBlock Grid.Row="0" Text="来源" Foreground="{DynamicResource Brush.TextSecondary}" />
                  <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding ComponentCenter.Source}" TextWrapping="Wrap" />
                  <TextBlock Grid.Row="1" Text="体积" Foreground="{DynamicResource Brush.TextSecondary}" />
                  <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding ComponentCenter.Size}" />
                  <TextBlock Grid.Row="2" Text="联网" Foreground="{DynamicResource Brush.TextSecondary}" />
                  <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding ComponentCenter.NetworkRequirement}" TextWrapping="Wrap" />
                  <TextBlock Grid.Row="3" Text="管理员权限" Foreground="{DynamicResource Brush.TextSecondary}" />
                  <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding ComponentCenter.AdministratorRequirement}" />
                  <TextBlock Grid.Row="4" Text="重启" Foreground="{DynamicResource Brush.TextSecondary}" />
                  <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding ComponentCenter.RestartRequirement}" />
                </Grid>

                <TextBlock Text="影响" FontWeight="SemiBold" Margin="0,16,0,2" />
                <TextBlock Text="{Binding ComponentCenter.UserImpact}" TextWrapping="Wrap" />
                <TextBlock Text="处理办法" FontWeight="SemiBold" Margin="0,12,0,2" />
                <TextBlock Text="{Binding ComponentCenter.OfflineInstructions}" TextWrapping="Wrap" />
                <TextBlock Text="{Binding ComponentCenter.AutomaticActionNotice}"
                           Foreground="{DynamicResource Brush.WarningText}"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap"
                           Margin="0,12,0,0" />
                <Button Content="重新检测"
                        Command="{Binding ComponentCenter.RefreshCommand}"
                        HorizontalAlignment="Left"
                        Margin="0,14,0,0"
                        automation:AutomationProperties.Name="重新检测 Plink 连接组件" />
              </StackPanel>
            </Border>
          </StackPanel>
        </ScrollViewer>
      </TabItem>

      <TabItem IsEnabled="False" Focusable="False">
        <TabItem.Header><StackPanel><TextBlock Text="设置" /><TextBlock Text="后续版本" FontSize="11" Foreground="{DynamicResource Brush.DisabledText}" /></StackPanel></TabItem.Header>
      </TabItem>
    </TabControl>
  </Grid>
  </Grid>
</Window>
