<Application x:Class="AssessmentTool.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:AssessmentTool.App.Converters">
  <Application.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="Themes/Colors.xaml" />
        <ResourceDictionary Source="Themes/Controls.xaml" />
        <ResourceDictionary Source="Themes/Fluent.xaml" />
      </ResourceDictionary.MergedDictionaries>
      <converters:DeviceMetadataConverter x:Key="DeviceMetadataConverter" />
    </ResourceDictionary>
  </Application.Resources>
</Application>
