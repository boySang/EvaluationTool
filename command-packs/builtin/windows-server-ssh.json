{
  "id": "windows-server-ssh",
  "name": "Windows Server SSH 只读识别与采集",
  "version": "1.0.0",
  "officialSource": "https://learn.microsoft.com/en-us/windows-server/administration/openssh/openssh-server-configuration",
  "commands": [
    {
      "id": "windows-server-ssh-product-name",
      "title": "读取 Windows Server 产品名称",
      "targetCategory": "Server",
      "commandText": "cmd.exe /d /c %SystemRoot%\\System32\\reg.exe query \"HKLM\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\" /v ProductName",
      "verificationStatus": "Verified",
      "isReadOnly": true,
      "vendor": "Microsoft",
      "productFamily": "Windows Server",
      "minimumVersion": null,
      "maximumVersion": null,
      "checkItem": "IDENTIFY",
      "modelRange": "*",
      "accountRequirement": "可读取 Windows CurrentVersion 注册表项的最小权限账户",
      "riskLevel": "Low",
      "timeoutSeconds": 45,
      "pagingBehavior": "NotApplicable",
      "resultDescription": "仅查询 ProductName 值以识别 Windows Server 版本和版本类型；不使用 reg add、delete、import 或 export。",
      "verificationDate": "2026-07-18",
      "officialSource": "https://learn.microsoft.com/en-us/windows-server/administration/windows-commands/reg-query"
    },
    {
      "id": "windows-server-ssh-build-number",
      "title": "读取 Windows Server 构建号",
      "targetCategory": "Server",
      "commandText": "cmd.exe /d /c %SystemRoot%\\System32\\reg.exe query \"HKLM\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\" /v CurrentBuildNumber",
      "verificationStatus": "Verified",
      "isReadOnly": true,
      "vendor": "Microsoft",
      "productFamily": "Windows Server",
      "minimumVersion": null,
      "maximumVersion": null,
      "checkItem": "IDENTIFY",
      "modelRange": "*",
      "accountRequirement": "可读取 Windows CurrentVersion 注册表项的最小权限账户",
      "riskLevel": "Low",
      "timeoutSeconds": 30,
      "pagingBehavior": "NotApplicable",
      "resultDescription": "仅查询 CurrentBuildNumber 值，为版本复核保留原始构建号证据。",
      "verificationDate": "2026-07-18",
      "officialSource": "https://learn.microsoft.com/en-us/windows-server/administration/windows-commands/reg-query"
    },
    {
      "id": "windows-server-ssh-account-policy",
      "title": "读取密码与账户锁定策略",
      "targetCategory": "Server",
      "commandText": "cmd.exe /d /c %SystemRoot%\\System32\\net.exe accounts",
      "verificationStatus": "Verified",
      "isReadOnly": true,
      "vendor": "Microsoft",
      "productFamily": "Windows Server",
      "minimumVersion": null,
      "maximumVersion": null,
      "checkItem": "身份鉴别",
      "modelRange": "*",
      "accountRequirement": "允许查看当前账户策略的最小权限账户",
      "riskLevel": "Low",
      "timeoutSeconds": 30,
      "pagingBehavior": "NotApplicable",
      "resultDescription": "不带任何修改参数运行 net accounts，显示当前密码期限、最小长度、历史和锁定策略；域环境结果仍需测评人员结合 GPO 复核。",
      "verificationDate": "2026-07-18",
      "officialSource": "https://learn.microsoft.com/en-us/troubleshoot/windows-server/networking/net-commands-on-operating-systems"
    }
  ]
}
